---
import type { Hike } from '../lib/catalog';
import type { Locale } from '../lib/i18n';
import { getClientTranslations } from '../lib/i18n';

interface Props {
  hikes: Hike[];
  locale?: Locale;
}

const { hikes, locale = 'fr' } = Astro.props;
const clientTranslations = getClientTranslations(locale);
---

<div
  id="hike-map"
  class="h-[40vh] sm:h-[50vh] md:h-[70vh] w-full rounded-lg border border-stone-200 dark:border-neutral-700"
  data-hikes={JSON.stringify(hikes)}
  data-translations={JSON.stringify(clientTranslations)}
  data-locale={locale}
></div>

<script>
  import L from 'leaflet';

  const mapElement = document.getElementById('hike-map')!;
  const hikes = JSON.parse(mapElement.dataset.hikes!);
  const translations = JSON.parse(mapElement.dataset.translations!);
  const locale = mapElement.dataset.locale || 'fr';

  const map = L.map('hike-map').setView([47.5, 3.0], 8);

  const ignAttribution = '&copy; <a href="https://www.ign.fr/">IGN</a>';

  const openTopoLayer = L.tileLayer(
    'https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png',
    { attribution: '&copy; <a href="https://opentopomap.org">OpenTopoMap</a> &middot; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>', maxZoom: 17 },
  ).addTo(map);

  const planIgnLayer = L.tileLayer(
    'https://data.geopf.fr/wmts?SERVICE=WMTS&REQUEST=GetTile&VERSION=1.0.0&LAYER=GEOGRAPHICALGRIDSYSTEMS.PLANIGNV2&STYLE=normal&FORMAT=image/png&TILEMATRIXSET=PM&TILEMATRIX={z}&TILEROW={y}&TILECOL={x}',
    { attribution: ignAttribution, maxZoom: 18 },
  );

  L.control.layers({ 'OpenTopoMap': openTopoLayer, 'Plan IGN': planIgnLayer }).addTo(map);

  const hikeLayerGroups: Map<string, L.LayerGroup> = new Map();
  const hikeGeojsonCache: Map<string, any> = new Map();

  function getThemeColors() {
    const style = getComputedStyle(document.documentElement);
    return {
      trail: style.getPropertyValue('--color-trail').trim(),
      stationStart: style.getPropertyValue('--color-station-start').trim(),
      stationIntermediate: style.getPropertyValue('--color-station-intermediate').trim(),
      stationEnd: style.getPropertyValue('--color-station-end').trim(),
    };
  }

  function buildHikeGroup(hike: any, geojson: any): L.LayerGroup {
    const colors = getThemeColors();
    const group = L.layerGroup();

    const trailLayer = L.geoJSON(geojson, {
      style: { color: colors.trail, weight: 3, opacity: 0.8 },
    });

    const hours = Math.floor(hike.estimated_duration_min / 60);
    const minutes = hike.estimated_duration_min % 60;
    const duration = hours > 0
      ? `${hours}h${minutes > 0 ? minutes + 'min' : ''}`
      : `${minutes}min`;

    const stepInfo = hike.step_count > 1
      ? `${hike.step_count} ${translations['map.steps']} &middot; `
      : '';

    const hikeUrl = locale === 'en' ? `/en/hike/${hike.slug}` : `/hike/${hike.slug}`;

    trailLayer.bindPopup(`
      <strong><a href="${hikeUrl}">${hike.path_ref}: ${hike.start_station.name} &rarr; ${hike.end_station.name}</a></strong><br>
      ${stepInfo}${hike.distance_km} km &middot; ${duration}<br>
      <a href="/data/${hike.gpx_path}" download>${translations['map.downloadGpx']}</a>
    `);

    group.addLayer(trailLayer);

    group.addLayer(L.circleMarker([hike.start_station.lat, hike.start_station.lon], {
      radius: 5, color: colors.stationStart, fillColor: colors.stationStart, fillOpacity: 0.8, weight: 1,
    }).bindTooltip(hike.start_station.name));

    if (hike.steps && hike.steps.length > 1) {
      for (let stepIndex = 1; stepIndex < hike.steps.length; stepIndex++) {
        const intermediateStation = hike.steps[stepIndex].start_station;
        group.addLayer(L.circleMarker([intermediateStation.lat, intermediateStation.lon], {
          radius: 4, color: colors.stationIntermediate, fillColor: colors.stationIntermediate, fillOpacity: 0.8, weight: 1,
        }).bindTooltip(intermediateStation.name));
      }
    }

    group.addLayer(L.circleMarker([hike.end_station.lat, hike.end_station.lon], {
      radius: 5, color: colors.stationEnd, fillColor: colors.stationEnd, fillOpacity: 0.8, weight: 1,
    }).bindTooltip(hike.end_station.name));

    return group;
  }

  function rebuildAllLayers() {
    const visibleIds = new Set<string>();
    hikeLayerGroups.forEach((group, hikeId) => {
      if (map.hasLayer(group)) {
        visibleIds.add(hikeId);
        map.removeLayer(group);
      }
    });
    hikeLayerGroups.clear();

    for (const hike of hikes) {
      const geojson = hikeGeojsonCache.get(hike.id);
      if (!geojson) continue;

      const group = buildHikeGroup(hike, geojson);
      hikeLayerGroups.set(hike.id, group);

      if (visibleIds.has(hike.id) || visibleIds.size === 0) {
        group.addTo(map);
      }
    }
  }

  async function loadSegments() {
    for (const hike of hikes) {
      if (!hike.geojson_path) continue;

      try {
        const response = await fetch(`/data/${hike.geojson_path}`);
        const geojson = await response.json();
        hikeGeojsonCache.set(hike.id, geojson);

        const group = buildHikeGroup(hike, geojson);
        group.addTo(map);
        hikeLayerGroups.set(hike.id, group);
      } catch (error) {
        console.error(`Failed to load GeoJSON for ${hike.id}:`, error);
      }
    }

    fitMapToVisible();
  }

  function fitMapToVisible() {
    const visibleLayers: L.Layer[] = [];
    hikeLayerGroups.forEach((group) => {
      if (map.hasLayer(group)) {
        group.eachLayer((layer) => visibleLayers.push(layer));
      }
    });
    if (visibleLayers.length > 0) {
      const featureGroup = L.featureGroup(visibleLayers);
      map.fitBounds(featureGroup.getBounds(), { padding: [20, 20] });
    }
  }

  document.addEventListener('hike-filter', ((event: CustomEvent<{ visibleIds: Set<string> }>) => {
    const { visibleIds } = event.detail;
    hikeLayerGroups.forEach((group, hikeId) => {
      if (visibleIds.has(hikeId)) {
        if (!map.hasLayer(group)) group.addTo(map);
      } else {
        if (map.hasLayer(group)) map.removeLayer(group);
      }
    });
    fitMapToVisible();
  }) as EventListener);

  document.addEventListener('theme-change', (() => {
    rebuildAllLayers();
  }) as EventListener);

  loadSegments();
</script>
