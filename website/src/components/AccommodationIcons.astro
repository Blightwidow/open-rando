---
import type { Locale } from '../lib/i18n';
import { t } from '../lib/i18n';

interface Props {
  hasHotel: boolean;
  hasCamping: boolean;
  size?: 'sm' | 'md';
  locale?: Locale;
}

const { hasHotel, hasCamping, size = 'sm', locale = 'fr' } = Astro.props;
const iconClass = size === 'sm' ? 'w-3.5 h-3.5' : 'w-4 h-4';
---

{hasHotel && (
  <span class="inline-flex items-center gap-1 text-purple-700 dark:text-purple-400" title={t(locale, 'accommodation.hotel')}>
    <svg class={iconClass} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M3 21h18M3 10l9-7 9 7M5 10v11M19 10v11M9 21v-6h6v6" />
    </svg>
  </span>
)}
{hasCamping && (
  <span class="inline-flex items-center gap-1 text-green-700 dark:text-green-400" title={t(locale, 'accommodation.camping')}>
    <svg class={iconClass} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M12 2L2 22h20L12 2z" />
      <path d="M12 12v6" />
    </svg>
  </span>
)}
