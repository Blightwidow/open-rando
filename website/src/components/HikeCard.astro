---
import type { Hike } from '../lib/catalog';
import { formatDuration } from '../lib/catalog';

interface Props {
  hike: Hike;
}

const { hike } = Astro.props;
---

<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 hover:shadow-md transition-shadow">
  <div class="flex items-start justify-between gap-2">
    <div>
      <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide">{hike.path_ref}</span>
      <h3 class="font-medium text-gray-900 mt-1">
        {hike.start_station.name} &rarr; {hike.end_station.name}
      </h3>
    </div>
  </div>
  <div class="flex gap-4 mt-3 text-sm text-gray-600">
    <span>{hike.distance_km} km</span>
    <span>{formatDuration(hike.estimated_duration_min)}</span>
  </div>
  <div class="mt-3">
    <a
      href={`/data/${hike.gpx_path}`}
      download
      class="inline-flex items-center gap-1 text-sm text-blue-600 hover:text-blue-800 font-medium"
    >
      Telecharger GPX
    </a>
  </div>
</div>
