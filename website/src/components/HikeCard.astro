---
import type { Hike } from '../lib/catalog';
import { formatDuration } from '../lib/catalog';
import type { Locale } from '../lib/i18n';
import { t } from '../lib/i18n';

interface Props {
  hike: Hike;
  locale?: Locale;
}

const { hike, locale = 'fr' } = Astro.props;
const stationNames = [
  ...hike.steps.map((step) => step.start_station.name),
  hike.steps[hike.steps.length - 1].end_station.name,
];
const maxStepDistance = Math.max(...hike.steps.map((step) => step.distance_km));

// Intermediate + end stations only (exclude first start station)
const overnightStations = [
  ...hike.steps.slice(1).map((step) => step.start_station),
  hike.steps[hike.steps.length - 1].end_station,
];
const hotelAllStops = overnightStations.length > 0 && overnightStations.every((station) => station.accommodation.has_hotel);
const campingAllStops = overnightStations.length > 0 && overnightStations.every((station) => station.accommodation.has_camping);

const hikeUrl = locale === 'en' ? `/en/hike/${hike.slug}` : `/hike/${hike.slug}`;

const difficultyLabel: Record<string, string> = {
  easy: t(locale, 'difficulty.easy'),
  moderate: t(locale, 'difficulty.moderate'),
  difficult: t(locale, 'difficulty.difficult'),
  very_difficult: t(locale, 'difficulty.very_difficult'),
};
---

<a
  href={hikeUrl}
  class="hike-card block bg-white dark:bg-neutral-800 rounded-lg shadow-sm border border-stone-200 dark:border-neutral-700 p-3 sm:p-4 hover:shadow-md hover:border-forest-400 dark:hover:border-forest-600 transition-all"
  data-hike-id={hike.id}
  data-step-count={hike.step_count}
  data-distance={hike.distance_km}
  data-max-step-distance={maxStepDistance}
  data-duration={hike.estimated_duration_min}
  data-hotel-all-stops={hotelAllStops}
  data-camping-all-stops={campingAllStops}
  data-elevation-gain={hike.elevation_gain_m}
>
  <div class="flex items-start justify-between gap-2">
    <div>
      <span class="text-xs font-semibold text-forest-700 dark:text-forest-400 uppercase tracking-wide">{hike.path_ref}</span>
      <h3 class="font-medium text-stone-900 dark:text-stone-100 mt-1">
        {hike.start_station.name} &rarr; {hike.end_station.name}
      </h3>
    </div>
    {hike.step_count > 1 && (
      <span class="text-xs bg-forest-100 text-forest-800 dark:bg-forest-800 dark:text-forest-200 px-2 py-0.5 rounded-full whitespace-nowrap">
        {t(locale, 'steps.label', { count: hike.step_count })}
      </span>
    )}
  </div>
  <div class="flex flex-wrap gap-x-4 gap-y-1 mt-3 text-sm text-stone-600 dark:text-stone-400">
    <span>{hike.distance_km} km</span>
    <span>{formatDuration(hike.estimated_duration_min)}</span>
    {hike.elevation_gain_m > 0 && <span>+{hike.elevation_gain_m}m</span>}
    {hike.difficulty !== 'unknown' && (
      <span class:list={[
        "text-xs px-2 py-0.5 rounded-full",
        hike.difficulty === 'easy' ? "bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300" :
        hike.difficulty === 'moderate' ? "bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300" :
        hike.difficulty === 'difficult' ? "bg-orange-100 text-orange-700 dark:bg-orange-900 dark:text-orange-300" :
        "bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300"
      ]}>
        {difficultyLabel[hike.difficulty] || hike.difficulty}
      </span>
    )}
  </div>
  {(hotelAllStops || campingAllStops) && (
    <div class="flex gap-2 mt-2">
      {hotelAllStops && <span class="text-xs bg-purple-100 text-purple-700 px-2 py-0.5 rounded-full">{t(locale, 'accommodation.hotel')}</span>}
      {campingAllStops && <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full">{t(locale, 'accommodation.camping')}</span>}
    </div>
  )}
  {hike.step_count > 1 && (
    <div class="mt-2 text-xs text-stone-500 dark:text-stone-400">
      {stationNames.join(' → ')}
    </div>
  )}
</a>
