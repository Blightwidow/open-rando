---
import type { Hike } from '../lib/catalog';
import { formatDuration } from '../lib/catalog';
import type { Locale } from '../lib/i18n';
import { t } from '../lib/i18n';
import AccommodationIcons from './AccommodationIcons.astro';

interface Props {
  hike: Hike;
  locale?: Locale;
}

const { hike, locale = 'fr' } = Astro.props;
const stationNames = [
  ...hike.steps.map((step) => step.start_station.name),
  hike.steps[hike.steps.length - 1].end_station.name,
];
const maxStepDistance = Math.max(...hike.steps.map((step) => step.distance_km));

// Intermediate + end stations only (exclude first start station)
const overnightStations = [
  ...hike.steps.slice(1).map((step) => step.start_station),
  hike.steps[hike.steps.length - 1].end_station,
];
const hotelAllStops = overnightStations.length > 0 && overnightStations.every((station) => station.accommodation.has_hotel);
const campingAllStops = overnightStations.length > 0 && overnightStations.every((station) => station.accommodation.has_camping);

const hikeUrl = locale === 'en' ? `/en/app/hike/${hike.slug}` : `/app/hike/${hike.slug}`;

const difficultyLabel: Record<string, string> = {
  easy: t(locale, 'difficulty.easy'),
  moderate: t(locale, 'difficulty.moderate'),
  difficult: t(locale, 'difficulty.difficult'),
  very_difficult: t(locale, 'difficulty.very_difficult'),
};

const difficultyTooltip: Record<string, string> = {
  easy: t(locale, 'difficulty.tooltip.easy'),
  moderate: t(locale, 'difficulty.tooltip.moderate'),
  difficult: t(locale, 'difficulty.tooltip.difficult'),
  very_difficult: t(locale, 'difficulty.tooltip.very_difficult'),
};

const terrainLabel: Record<string, string> = {
  coastal: t(locale, 'terrain.coastal'),
  mountain: t(locale, 'terrain.mountain'),
  hills: t(locale, 'terrain.hills'),
  forest: t(locale, 'terrain.forest'),
  plains: t(locale, 'terrain.plains'),
};

const terrainColor: Record<string, string> = {
  coastal: 'bg-cyan-100 text-cyan-700 dark:bg-cyan-900 dark:text-cyan-300',
  mountain: 'bg-slate-200 text-slate-700 dark:bg-slate-700 dark:text-slate-300',
  hills: 'bg-amber-100 text-amber-700 dark:bg-amber-900 dark:text-amber-300',
  forest: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900 dark:text-emerald-300',
  plains: 'bg-lime-100 text-lime-700 dark:bg-lime-900 dark:text-lime-300',
};
---

<a
  href={hikeUrl}
  class="hike-card block bg-white dark:bg-neutral-800 rounded-lg shadow-sm border border-stone-200 dark:border-neutral-700 p-3 sm:p-4 hover:shadow-md hover:border-forest-400 dark:hover:border-forest-600 transition-all"
  data-hike-id={hike.id}
  data-step-count={hike.step_count}
  data-distance={hike.distance_km}
  data-max-step-distance={maxStepDistance}
  data-duration={hike.estimated_duration_min}
  data-hotel-all-stops={hotelAllStops}
  data-camping-all-stops={campingAllStops}
  data-elevation-gain={hike.elevation_gain_m}
  data-route-type={hike.route_type}
  data-difficulty={hike.difficulty}
  data-region={hike.region}
  data-terrain={(hike.terrain || []).join(',')}
>
  <div class="flex items-start justify-between gap-2">
    <div>
      <span class:list={[
        "text-xs font-semibold uppercase tracking-wide",
        hike.route_type === 'pr'
          ? "text-blue-700 dark:text-blue-400"
          : "text-forest-700 dark:text-forest-400"
      ]}>{hike.path_ref}</span>
      <h3 class="font-medium text-stone-900 dark:text-stone-100 mt-1">
        {hike.is_round_trip
          ? t(locale, 'hike.loopFrom', { station: hike.start_station.name })
          : `${hike.start_station.name} → ${hike.end_station.name}`}
      </h3>
    </div>
    <div class="flex gap-1.5">
      {hike.is_round_trip && (
        <span class="text-xs bg-sky-100 text-sky-800 dark:bg-sky-900 dark:text-sky-200 px-2 py-0.5 rounded-full whitespace-nowrap">
          {t(locale, 'hike.loop')}
        </span>
      )}
      {hike.step_count > 1 && (
        <span class="text-xs bg-forest-100 text-forest-800 dark:bg-forest-800 dark:text-forest-200 px-2 py-0.5 rounded-full whitespace-nowrap">
          {t(locale, 'steps.label', { count: hike.step_count })}
        </span>
      )}
    </div>
  </div>
  <div class="flex flex-wrap gap-x-4 gap-y-1 mt-3 text-sm text-stone-600 dark:text-stone-400">
    <span>{hike.distance_km} km</span>
    <span>{formatDuration(hike.estimated_duration_min)}</span>
    {hike.elevation_gain_m > 0 && <span>+{hike.elevation_gain_m}m</span>}
    {hike.difficulty !== 'unknown' && (
      <span
        title={difficultyTooltip[hike.difficulty]}
        class:list={[
        "text-xs px-2 py-0.5 rounded-full cursor-help",
        hike.difficulty === 'easy' ? "bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300" :
        hike.difficulty === 'moderate' ? "bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300" :
        hike.difficulty === 'difficult' ? "bg-orange-100 text-orange-700 dark:bg-orange-900 dark:text-orange-300" :
        "bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300"
      ]}>
        {difficultyLabel[hike.difficulty] || hike.difficulty}
      </span>
    )}
    {hike.region && (
      <span class="text-xs text-stone-500 dark:text-stone-400">{hike.region}</span>
    )}
    {(hike.terrain || []).map((tag) => (
      <span class:list={["text-xs px-2 py-0.5 rounded-full", terrainColor[tag] || 'bg-stone-100 text-stone-600']}>
        {terrainLabel[tag] || tag}
      </span>
    ))}
  </div>
  {(hotelAllStops || campingAllStops) && (
    <div class="flex items-center gap-2 mt-2">
      <AccommodationIcons hasHotel={hotelAllStops} hasCamping={campingAllStops} size="sm" />
    </div>
  )}
  {hike.step_count > 1 && (
    <div class="mt-2 text-xs text-stone-500 dark:text-stone-400">
      {stationNames.join(' → ')}
    </div>
  )}
  <div class="suggest-annotation hidden mt-2 text-xs text-forest-700 dark:text-forest-400 font-medium"></div>
</a>
