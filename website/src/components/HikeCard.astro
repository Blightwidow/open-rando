---
import type { Hike } from '../lib/catalog';
import { formatDuration } from '../lib/catalog';

interface Props {
  hike: Hike;
}

const { hike } = Astro.props;
const stationNames = [
  ...hike.steps.map((step) => step.start_station.name),
  hike.steps[hike.steps.length - 1].end_station.name,
];
const maxStepDistance = Math.max(...hike.steps.map((step) => step.distance_km));
---

<a
  href={`/hike/${hike.slug}`}
  class="hike-card block bg-white rounded-lg shadow-sm border border-gray-200 p-4 hover:shadow-md transition-shadow"
  data-hike-id={hike.id}
  data-step-count={hike.step_count}
  data-distance={hike.distance_km}
  data-max-step-distance={maxStepDistance}
  data-duration={hike.estimated_duration_min}
>
  <div class="flex items-start justify-between gap-2">
    <div>
      <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide">{hike.path_ref}</span>
      <h3 class="font-medium text-gray-900 mt-1">
        {hike.start_station.name} &rarr; {hike.end_station.name}
      </h3>
    </div>
    {hike.step_count > 1 && (
      <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full whitespace-nowrap">
        {hike.step_count} etapes
      </span>
    )}
  </div>
  <div class="flex gap-4 mt-3 text-sm text-gray-600">
    <span>{hike.distance_km} km</span>
    <span>{formatDuration(hike.estimated_duration_min)}</span>
  </div>
  {hike.step_count > 1 && (
    <div class="mt-2 text-xs text-gray-500">
      {stationNames.join(' → ')}
    </div>
  )}
</a>
