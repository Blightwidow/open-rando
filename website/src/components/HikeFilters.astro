---
import type { Hike } from '../lib/catalog';
import type { Locale } from '../lib/i18n';
import { t, getClientTranslations } from '../lib/i18n';

interface Props {
  hikes: Hike[];
  locale?: Locale;
}

const { hikes, locale = 'fr' } = Astro.props;

const maxStepDistance = Math.ceil(
  Math.max(...hikes.flatMap((hike) => hike.steps.map((step) => step.distance_km)))
);
const maxSteps = Math.max(...hikes.map((hike) => hike.step_count));
const regions = [...new Set(hikes.map((hike) => hike.region).filter(Boolean))].sort();
const clientTranslations = getClientTranslations(locale);
---

<div
  id="hike-filters"
  class="space-y-4"
  data-translations={JSON.stringify(clientTranslations)}
>
  <div class="flex items-center justify-between">
    <h3 class="text-sm font-semibold text-stone-700 dark:text-stone-200">{t(locale, 'filters.title')}</h3>
    <button
      id="reset-filters"
      class="text-xs text-forest-700 dark:text-forest-400 hover:text-forest-900 dark:hover:text-forest-300 underline hidden"
    >
      {t(locale, 'filters.reset')}
    </button>
  </div>
  <div id="filter-panel" class="space-y-4">
    <div class="grid gap-4">
      <div>
        <label class="block text-xs text-stone-500 dark:text-stone-400 mb-1">
          {t(locale, 'filters.maxStep')}: <span id="max-step-value">&le; 20 km</span>
        </label>
        <input type="range" id="max-step-distance" min="0" max={maxStepDistance} value="20" step="1" class="w-full accent-forest-700 dark:accent-forest-400" />
      </div>
      <div>
        <label class="block text-xs text-stone-500 dark:text-stone-400 mb-1">
          {t(locale, 'filters.steps')}: <span id="steps-value">1 – {maxSteps}</span>
        </label>
        <div class="flex gap-2 items-center">
          <input type="range" id="steps-min" min="1" max={maxSteps} value="1" step="1" class="w-full accent-forest-700 dark:accent-forest-400" />
          <input type="range" id="steps-max" min="1" max={maxSteps} value={maxSteps} step="1" class="w-full accent-forest-700 dark:accent-forest-400" />
        </div>
      </div>
    </div>
    <div>
      <p class="text-xs text-stone-500 dark:text-stone-400 mb-2">{t(locale, 'filters.accommodation')}</p>
      <div class="flex flex-wrap gap-3">
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" id="filter-hotel" class="accent-purple-600 w-4 h-4" />
          <span class="text-xs px-2 py-0.5 rounded-full bg-purple-100 text-purple-700 dark:bg-purple-900 dark:text-purple-300">{t(locale, 'filters.hotel')}</span>
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" id="filter-camping" class="accent-green-600 w-4 h-4" />
          <span class="text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300">{t(locale, 'filters.camping')}</span>
        </label>
      </div>
    </div>
    <div>
      <p class="text-xs text-stone-500 dark:text-stone-400 mb-2">{t(locale, 'filters.difficulty')}</p>
      <div class="flex flex-wrap gap-3">
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" id="filter-diff-easy" class="accent-green-600 w-4 h-4" />
          <span title={t(locale, 'difficulty.tooltip.easy')} class="text-xs px-2 py-0.5 rounded-full cursor-help bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300">{t(locale, 'difficulty.easy')}</span>
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" id="filter-diff-moderate" class="accent-yellow-500 w-4 h-4" />
          <span title={t(locale, 'difficulty.tooltip.moderate')} class="text-xs px-2 py-0.5 rounded-full cursor-help bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300">{t(locale, 'difficulty.moderate')}</span>
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" id="filter-diff-difficult" class="accent-orange-500 w-4 h-4" />
          <span title={t(locale, 'difficulty.tooltip.difficult')} class="text-xs px-2 py-0.5 rounded-full cursor-help bg-orange-100 text-orange-700 dark:bg-orange-900 dark:text-orange-300">{t(locale, 'difficulty.difficult')}</span>
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" id="filter-diff-very-difficult" class="accent-red-500 w-4 h-4" />
          <span title={t(locale, 'difficulty.tooltip.very_difficult')} class="text-xs px-2 py-0.5 rounded-full cursor-help bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300">{t(locale, 'difficulty.very_difficult')}</span>
        </label>
      </div>
    </div>
    <div>
      <p class="text-xs text-stone-500 dark:text-stone-400 mb-2">{t(locale, 'filters.trailType')}</p>
      <div class="flex gap-4">
        <label class="flex items-center gap-2 text-sm text-stone-700 dark:text-stone-300 cursor-pointer">
          <input type="checkbox" id="filter-type-gr" class="accent-forest-700 w-4 h-4" />
          <span class="text-xs font-semibold text-forest-700 dark:text-forest-400 uppercase">{t(locale, 'filters.trailType.gr')}</span>
        </label>
        <label class="flex items-center gap-2 text-sm text-stone-700 dark:text-stone-300 cursor-pointer">
          <input type="checkbox" id="filter-type-grp" class="accent-forest-700 w-4 h-4" />
          <span class="text-xs font-semibold text-forest-700 dark:text-forest-400 uppercase">{t(locale, 'filters.trailType.grp')}</span>
        </label>
        <label class="flex items-center gap-2 text-sm text-stone-700 dark:text-stone-300 cursor-pointer">
          <input type="checkbox" id="filter-type-pr" class="accent-blue-700 w-4 h-4" />
          <span class="text-xs font-semibold text-blue-700 dark:text-blue-400 uppercase">{t(locale, 'filters.trailType.pr')}</span>
        </label>
      </div>
    </div>
    {regions.length > 0 && (
      <div>
        <p class="text-xs text-stone-500 dark:text-stone-400 mb-2">{t(locale, 'filters.region')}</p>
        <div class="flex flex-wrap gap-3">
          {regions.map((region) => (
            <label class="flex items-center gap-1.5 cursor-pointer">
              <input type="checkbox" class="filter-region accent-forest-700 w-4 h-4" data-region={region} />
              <span class="text-xs px-2 py-0.5 rounded-full bg-stone-100 text-stone-700 dark:bg-stone-700 dark:text-stone-300">{region}</span>
            </label>
          ))}
        </div>
      </div>
    )}
    <div>
      <p class="text-xs text-stone-500 dark:text-stone-400 mb-2">{t(locale, 'filters.terrain')}</p>
      <div class="flex flex-wrap gap-3">
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" id="filter-terrain-coastal" class="accent-cyan-600 w-4 h-4" />
          <span class="text-xs px-2 py-0.5 rounded-full bg-cyan-100 text-cyan-700 dark:bg-cyan-900 dark:text-cyan-300">{t(locale, 'terrain.coastal')}</span>
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" id="filter-terrain-mountain" class="accent-slate-600 w-4 h-4" />
          <span class="text-xs px-2 py-0.5 rounded-full bg-slate-200 text-slate-700 dark:bg-slate-700 dark:text-slate-300">{t(locale, 'terrain.mountain')}</span>
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" id="filter-terrain-hills" class="accent-amber-600 w-4 h-4" />
          <span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 dark:bg-amber-900 dark:text-amber-300">{t(locale, 'terrain.hills')}</span>
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" id="filter-terrain-forest" class="accent-emerald-600 w-4 h-4" />
          <span class="text-xs px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 dark:bg-emerald-900 dark:text-emerald-300">{t(locale, 'terrain.forest')}</span>
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" id="filter-terrain-plains" class="accent-lime-600 w-4 h-4" />
          <span class="text-xs px-2 py-0.5 rounded-full bg-lime-100 text-lime-700 dark:bg-lime-900 dark:text-lime-300">{t(locale, 'terrain.plains')}</span>
        </label>
      </div>
    </div>
  </div>
</div>

<script>
  const filtersContainer = document.getElementById('hike-filters')!;
  const translations = JSON.parse(filtersContainer.dataset.translations || '{}');

  const maxStepDistance = document.getElementById('max-step-distance') as HTMLInputElement;
  const stepsMin = document.getElementById('steps-min') as HTMLInputElement;
  const stepsMax = document.getElementById('steps-max') as HTMLInputElement;

  const maxStepValue = document.getElementById('max-step-value')!;
  const stepsValue = document.getElementById('steps-value')!;
  const hikeCount = document.getElementById('hike-count');
  const filterHotel = document.getElementById('filter-hotel') as HTMLInputElement;
  const filterCamping = document.getElementById('filter-camping') as HTMLInputElement;
  const filterDiffEasy = document.getElementById('filter-diff-easy') as HTMLInputElement;
  const filterDiffModerate = document.getElementById('filter-diff-moderate') as HTMLInputElement;
  const filterDiffDifficult = document.getElementById('filter-diff-difficult') as HTMLInputElement;
  const filterDiffVeryDifficult = document.getElementById('filter-diff-very-difficult') as HTMLInputElement;
  const filterTypeGr = document.getElementById('filter-type-gr') as HTMLInputElement;
  const filterTypeGrp = document.getElementById('filter-type-grp') as HTMLInputElement;
  const filterTypePr = document.getElementById('filter-type-pr') as HTMLInputElement;
  const regionCheckboxes = document.querySelectorAll<HTMLInputElement>('.filter-region');
  const filterTerrainCoastal = document.getElementById('filter-terrain-coastal') as HTMLInputElement;
  const filterTerrainMountain = document.getElementById('filter-terrain-mountain') as HTMLInputElement;
  const filterTerrainHills = document.getElementById('filter-terrain-hills') as HTMLInputElement;
  const filterTerrainForest = document.getElementById('filter-terrain-forest') as HTMLInputElement;
  const filterTerrainPlains = document.getElementById('filter-terrain-plains') as HTMLInputElement;
  const resetButton = document.getElementById('reset-filters') as HTMLElement;
  const hikeList = document.getElementById('hike-list');
  const hikeEmpty = document.getElementById('hike-empty');

  // Store default values for reset detection
  const defaults = {
    maxStepDistance: '20',
    stepsMin: stepsMin.min,
    stepsMax: stepsMax.max,
    hotel: false,
    camping: false,
    diffEasy: false,
    diffModerate: false,
    diffDifficult: false,
    diffVeryDifficult: false,
    typeGr: false,
    typeGrp: false,
    typePr: false,
  };

  function formatHikeCount(count: number): string {
    if (count === 0) return translations['hikes.count.zero'] || '0';
    if (count === 1) return translations['hikes.count.one'] || '1';
    return (translations['hikes.count.many'] || '{count}').replace('{count}', String(count));
  }

  function isNonDefault(): boolean {
    const anyRegionChecked = Array.from(regionCheckboxes).some((checkbox) => checkbox.checked);
    const anyTerrainChecked = filterTerrainCoastal.checked || filterTerrainMountain.checked ||
      filterTerrainHills.checked || filterTerrainForest.checked || filterTerrainPlains.checked;
    return (
      maxStepDistance.value !== defaults.maxStepDistance ||
      stepsMin.value !== defaults.stepsMin ||
      stepsMax.value !== defaults.stepsMax ||
      filterHotel.checked !== defaults.hotel ||
      filterCamping.checked !== defaults.camping ||
      filterDiffEasy.checked !== defaults.diffEasy ||
      filterDiffModerate.checked !== defaults.diffModerate ||
      filterDiffDifficult.checked !== defaults.diffDifficult ||
      filterDiffVeryDifficult.checked !== defaults.diffVeryDifficult ||
      filterTypeGr.checked !== defaults.typeGr ||
      filterTypeGrp.checked !== defaults.typeGrp ||
      filterTypePr.checked !== defaults.typePr ||
      anyRegionChecked ||
      anyTerrainChecked
    );
  }

  function resetFilters() {
    maxStepDistance.value = defaults.maxStepDistance;
    stepsMin.value = defaults.stepsMin;
    stepsMax.value = defaults.stepsMax;
    filterHotel.checked = false;
    filterCamping.checked = false;
    filterDiffEasy.checked = false;
    filterDiffModerate.checked = false;
    filterDiffDifficult.checked = false;
    filterDiffVeryDifficult.checked = false;
    filterTypeGr.checked = false;
    filterTypeGrp.checked = false;
    filterTypePr.checked = false;
    regionCheckboxes.forEach((checkbox) => { checkbox.checked = false; });
    filterTerrainCoastal.checked = false;
    filterTerrainMountain.checked = false;
    filterTerrainHills.checked = false;
    filterTerrainForest.checked = false;
    filterTerrainPlains.checked = false;
    applyFilters();
  }

  // URL state management
  function readFiltersFromUrl() {
    const params = new URLSearchParams(window.location.search);
    if (params.has('step')) maxStepDistance.value = params.get('step')!;
    if (params.has('smin')) stepsMin.value = params.get('smin')!;
    if (params.has('smax')) stepsMax.value = params.get('smax')!;
    if (params.has('hotel')) filterHotel.checked = params.get('hotel') === '1';
    if (params.has('camping')) filterCamping.checked = params.get('camping') === '1';
    if (params.has('diff')) {
      const difficulties = params.get('diff')!.split(',');
      filterDiffEasy.checked = difficulties.includes('easy');
      filterDiffModerate.checked = difficulties.includes('moderate');
      filterDiffDifficult.checked = difficulties.includes('difficult');
      filterDiffVeryDifficult.checked = difficulties.includes('very_difficult');
    }
    if (params.has('type')) {
      const types = params.get('type')!.split(',');
      filterTypeGr.checked = types.includes('gr');
      filterTypeGrp.checked = types.includes('grp');
      filterTypePr.checked = types.includes('pr');
    }
    if (params.has('region')) {
      const selectedRegions = params.get('region')!.split(',');
      regionCheckboxes.forEach((checkbox) => {
        checkbox.checked = selectedRegions.includes(checkbox.dataset.region || '');
      });
    }
    if (params.has('terrain')) {
      const terrains = params.get('terrain')!.split(',');
      filterTerrainCoastal.checked = terrains.includes('coastal');
      filterTerrainMountain.checked = terrains.includes('mountain');
      filterTerrainHills.checked = terrains.includes('hills');
      filterTerrainForest.checked = terrains.includes('forest');
      filterTerrainPlains.checked = terrains.includes('plains');
    }
  }

  let urlUpdateTimer: ReturnType<typeof setTimeout> | null = null;

  function writeFiltersToUrl() {
    if (urlUpdateTimer) clearTimeout(urlUpdateTimer);
    urlUpdateTimer = setTimeout(() => {
      const params = new URLSearchParams();
      if (maxStepDistance.value !== defaults.maxStepDistance) params.set('step', maxStepDistance.value);
      if (stepsMin.value !== defaults.stepsMin) params.set('smin', stepsMin.value);
      if (stepsMax.value !== defaults.stepsMax) params.set('smax', stepsMax.value);
      if (filterHotel.checked) params.set('hotel', '1');
      if (filterCamping.checked) params.set('camping', '1');
      const activeDifficulties = [
        filterDiffEasy.checked ? 'easy' : null,
        filterDiffModerate.checked ? 'moderate' : null,
        filterDiffDifficult.checked ? 'difficult' : null,
        filterDiffVeryDifficult.checked ? 'very_difficult' : null,
      ].filter(Boolean);
      if (activeDifficulties.length > 0) params.set('diff', activeDifficulties.join(','));
      const activeTypes = [
        filterTypeGr.checked ? 'gr' : null,
        filterTypeGrp.checked ? 'grp' : null,
        filterTypePr.checked ? 'pr' : null,
      ].filter(Boolean);
      if (activeTypes.length > 0) params.set('type', activeTypes.join(','));
      const activeRegions = Array.from(regionCheckboxes)
        .filter((checkbox) => checkbox.checked)
        .map((checkbox) => checkbox.dataset.region!)
        .filter(Boolean);
      if (activeRegions.length > 0) params.set('region', activeRegions.join(','));
      const activeTerrains = [
        filterTerrainCoastal.checked ? 'coastal' : null,
        filterTerrainMountain.checked ? 'mountain' : null,
        filterTerrainHills.checked ? 'hills' : null,
        filterTerrainForest.checked ? 'forest' : null,
        filterTerrainPlains.checked ? 'plains' : null,
      ].filter(Boolean);
      if (activeTerrains.length > 0) params.set('terrain', activeTerrains.join(','));

      const queryString = params.toString();
      const newUrl = queryString ? `${window.location.pathname}?${queryString}` : window.location.pathname;
      history.replaceState(null, '', newUrl);
    }, 150);
  }

  function applyFilters() {
    const activeDifficulties = new Set([
      filterDiffEasy.checked ? 'easy' : null,
      filterDiffModerate.checked ? 'moderate' : null,
      filterDiffDifficult.checked ? 'difficult' : null,
      filterDiffVeryDifficult.checked ? 'very_difficult' : null,
    ].filter(Boolean) as string[]);

    const activeRouteTypes = new Set([
      filterTypeGr.checked ? 'gr' : null,
      filterTypeGrp.checked ? 'grp' : null,
      filterTypePr.checked ? 'pr' : null,
    ].filter(Boolean) as string[]);

    const activeRegions = new Set(
      Array.from(regionCheckboxes)
        .filter((checkbox) => checkbox.checked)
        .map((checkbox) => checkbox.dataset.region!)
    );

    const activeTerrains = new Set([
      filterTerrainCoastal.checked ? 'coastal' : null,
      filterTerrainMountain.checked ? 'mountain' : null,
      filterTerrainHills.checked ? 'hills' : null,
      filterTerrainForest.checked ? 'forest' : null,
      filterTerrainPlains.checked ? 'plains' : null,
    ].filter(Boolean) as string[]);

    const filters = {
      maxStepDistance: parseFloat(maxStepDistance.value),
      stepsMin: parseInt(stepsMin.value),
      stepsMax: parseInt(stepsMax.value),
      requireHotel: filterHotel.checked,
      requireCamping: filterCamping.checked,
    };

    maxStepValue.textContent = `≤ ${filters.maxStepDistance} km`;
    stepsValue.textContent = `${filters.stepsMin} – ${filters.stepsMax}`;

    const cards = document.querySelectorAll<HTMLElement>('.hike-card');
    let visibleCount = 0;
    const visibleIds = new Set<string>();

    cards.forEach((card) => {
      const stepDistance = parseFloat(card.dataset.maxStepDistance || '0');
      const stepCount = parseInt(card.dataset.stepCount || '1');
      const hasHotelAllStops = card.dataset.hotelAllStops === 'true';
      const hasCampingAllStops = card.dataset.campingAllStops === 'true';
      const difficulty = card.dataset.difficulty || '';

      const suggestHidden = card.dataset.suggestHidden === '1';

      const cardRegion = card.dataset.region || '';
      const cardTerrainTags = (card.dataset.terrain || '').split(',').filter(Boolean);
      const terrainMatch = activeTerrains.size === 0 || cardTerrainTags.some((tag) => activeTerrains.has(tag));

      const visible =
        !suggestHidden &&
        stepDistance <= filters.maxStepDistance &&
        stepCount >= filters.stepsMin &&
        stepCount <= filters.stepsMax &&
        (!filters.requireHotel || hasHotelAllStops) &&
        (!filters.requireCamping || hasCampingAllStops) &&
        (activeDifficulties.size === 0 || activeDifficulties.has(difficulty)) &&
        (activeRouteTypes.size === 0 || activeRouteTypes.has(card.dataset.routeType || '')) &&
        (activeRegions.size === 0 || activeRegions.has(cardRegion)) &&
        terrainMatch;

      card.style.display = visible ? '' : 'none';
      if (visible) {
        visibleCount++;
        visibleIds.add(card.dataset.hikeId || '');
      }
    });

    if (hikeCount) {
      hikeCount.textContent = formatHikeCount(visibleCount);
    }

    // Show/hide empty state
    if (hikeList && hikeEmpty) {
      if (visibleCount === 0 && cards.length > 0) {
        hikeList.classList.add('hidden');
        hikeEmpty.classList.remove('hidden');
      } else {
        hikeList.classList.remove('hidden');
        hikeEmpty.classList.add('hidden');
      }
    }

    // Show/hide reset button
    if (resetButton) {
      resetButton.classList.toggle('hidden', !isNonDefault());
    }

    document.dispatchEvent(new CustomEvent('hike-filter', { detail: { visibleIds } }));
    writeFiltersToUrl();
  }

  // Event listeners
  [maxStepDistance, stepsMin, stepsMax].forEach(
    (input) => input.addEventListener('input', applyFilters)
  );
  [filterHotel, filterCamping, filterDiffEasy, filterDiffModerate, filterDiffDifficult, filterDiffVeryDifficult, filterTypeGr, filterTypeGrp, filterTypePr, filterTerrainCoastal, filterTerrainMountain, filterTerrainHills, filterTerrainForest, filterTerrainPlains].forEach(
    (input) => input.addEventListener('change', applyFilters)
  );
  regionCheckboxes.forEach((input) => input.addEventListener('change', applyFilters));

  if (resetButton) {
    resetButton.addEventListener('click', resetFilters);
  }

  // Listen for reset from empty state button
  document.addEventListener('reset-filters', resetFilters);

  // Re-run filters when suggest changes card visibility
  document.addEventListener('suggest-changed', applyFilters);

  // Initialize from URL params, then apply
  readFiltersFromUrl();
  applyFilters();
</script>
