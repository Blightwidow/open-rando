---
import type { Hike } from '../lib/catalog';
import type { Locale } from '../lib/i18n';
import { t } from '../lib/i18n';
import HikeCard from './HikeCard.astro';

interface Props {
  hikes: Hike[];
  locale?: Locale;
}

const { hikes, locale = 'fr' } = Astro.props;
---

<div id="hike-list" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
  {hikes.map((hike) => <HikeCard hike={hike} locale={locale} />)}
</div>
<div id="hike-empty" class="hidden text-center py-12">
  <p class="text-stone-500 dark:text-stone-400">{t(locale, 'filters.noResults')}</p>
  <button
    id="reset-filters-empty"
    class="mt-3 text-sm text-forest-700 dark:text-forest-400 hover:text-forest-900 dark:hover:text-forest-300 underline"
  >
    {t(locale, 'filters.resetFilters')}
  </button>
</div>

<script>
  const resetButton = document.getElementById('reset-filters-empty');
  if (resetButton) {
    resetButton.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('reset-filters'));
    });
  }
</script>
