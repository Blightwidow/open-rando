---
import type { Hike } from '../lib/catalog';
import type { Locale } from '../lib/i18n';
import { t, getClientTranslations } from '../lib/i18n';
import { extractStations, buildHikeStationIndex } from '../lib/suggest';

interface Props {
  hikes: Hike[];
  locale?: Locale;
}

const { hikes, locale = 'fr' } = Astro.props;

const stations = extractStations(hikes);
const hikeStationIndex = buildHikeStationIndex(hikes);
const clientTranslations = getClientTranslations(locale);
---

<div
  id="hike-suggest"
  class="bg-white dark:bg-neutral-800 rounded-lg border border-stone-200 dark:border-neutral-700 p-4 space-y-4"
  data-stations={JSON.stringify(stations)}
  data-hike-index={JSON.stringify(hikeStationIndex)}
  data-translations={JSON.stringify(clientTranslations)}
>
  <h3 class="text-sm font-semibold text-stone-700 dark:text-stone-200">
    {t(locale, 'suggest.title')}
  </h3>

  <div class="flex flex-col sm:flex-row gap-3">
    <!-- Station autocomplete -->
    <div class="relative flex-1">
      <input
        id="suggest-station-input"
        type="text"
        placeholder={t(locale, 'suggest.stationPlaceholder')}
        autocomplete="off"
        class="w-full px-3 py-2 text-sm rounded-md border border-stone-300 dark:border-neutral-600 bg-white dark:bg-neutral-700 text-stone-900 dark:text-stone-100 placeholder-stone-400 dark:placeholder-stone-500 focus:outline-none focus:ring-2 focus:ring-forest-500 dark:focus:ring-forest-400"
      />
      <ul
        id="suggest-station-list"
        class="hidden absolute z-10 mt-1 w-full bg-white dark:bg-neutral-700 border border-stone-200 dark:border-neutral-600 rounded-md shadow-lg max-h-48 overflow-y-auto"
        role="listbox"
      >
      </ul>
    </div>

    <!-- Time budget presets -->
    <div id="suggest-time-presets" class="flex flex-wrap gap-2">
      {[
        { key: 'suggest.time.halfDay', minutes: 240 },
        { key: 'suggest.time.fullDay', minutes: 480 },
        { key: 'suggest.time.weekend', minutes: 960 },
        { key: 'suggest.time.multiDay', minutes: 1440 },
      ].map(({ key, minutes }) => (
        <button
          class="suggest-time-chip px-3 py-1.5 text-xs rounded-full border border-stone-300 dark:border-neutral-600 text-stone-600 dark:text-stone-400 hover:border-forest-500 dark:hover:border-forest-400 hover:text-forest-700 dark:hover:text-forest-300 transition-colors"
          data-minutes={minutes}
        >
          {t(locale, key)}
        </button>
      ))}
    </div>
  </div>

  <!-- Status row: result count + clear button -->
  <div id="suggest-status" class="hidden flex items-center justify-between text-xs">
    <span id="suggest-result-count" class="text-stone-500 dark:text-stone-400"></span>
    <button
      id="suggest-clear"
      class="text-forest-700 dark:text-forest-400 hover:text-forest-900 dark:hover:text-forest-300 underline"
    >
      {t(locale, 'suggest.clear')}
    </button>
  </div>
</div>

<script>
  import { normalize, findSuggestions } from '../lib/suggest';
  import type { StationEntry, HikeIndexEntry, Suggestion } from '../lib/suggest';
  import { formatDuration } from '../lib/format';

  const container = document.getElementById('hike-suggest')!;
  const stationInput = document.getElementById('suggest-station-input') as HTMLInputElement;
  const stationList = document.getElementById('suggest-station-list') as HTMLUListElement;
  const statusRow = document.getElementById('suggest-status')!;
  const resultCount = document.getElementById('suggest-result-count')!;
  const clearButton = document.getElementById('suggest-clear')!;
  const timeChips = document.querySelectorAll<HTMLButtonElement>('.suggest-time-chip');

  const stations: StationEntry[] = JSON.parse(container.dataset.stations || '[]');
  const hikeIndex: HikeIndexEntry[] = JSON.parse(container.dataset.hikeIndex || '[]');
  const translations: Record<string, string> = JSON.parse(container.dataset.translations || '{}');

  let selectedStationCode: string | null = null;
  let selectedMinutes: number | null = null;

  // ── Autocomplete ──────────────────────────────────────────────────────────
  function showDropdown(query: string) {
    const normalizedQuery = normalize(query);
    const matches = stations
      .filter((station) => normalize(station.name).includes(normalizedQuery))
      .slice(0, 8);

    stationList.innerHTML = '';
    if (matches.length === 0 || query.length < 2) {
      stationList.classList.add('hidden');
      return;
    }

    matches.forEach((station) => {
      const item = document.createElement('li');
      item.role = 'option';
      item.className =
        'px-3 py-2 text-sm text-stone-900 dark:text-stone-100 cursor-pointer hover:bg-forest-50 dark:hover:bg-neutral-600';
      item.textContent = station.name;
      item.addEventListener('mousedown', (event) => {
        event.preventDefault(); // prevent input blur before click fires
        selectStation(station);
      });
      stationList.appendChild(item);
    });

    stationList.classList.remove('hidden');
  }

  function selectStation(station: StationEntry) {
    stationInput.value = station.name;
    selectedStationCode = station.code;
    stationList.classList.add('hidden');
    runSuggest();
  }

  stationInput.addEventListener('input', () => {
    selectedStationCode = null; // clear selection when user types
    showDropdown(stationInput.value);
    runSuggest();
    writeToUrl(selectedStationCode, selectedMinutes);
  });

  stationInput.addEventListener('blur', () => {
    // Delay so mousedown on list item fires first
    setTimeout(() => stationList.classList.add('hidden'), 150);
  });

  stationInput.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      stationList.classList.add('hidden');
    }
  });

  // ── Time chip selection ───────────────────────────────────────────────────
  timeChips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const minutes = parseInt(chip.dataset.minutes || '0');
      if (selectedMinutes === minutes) {
        // Toggle off
        selectedMinutes = null;
        chip.classList.remove('bg-forest-100', 'dark:bg-forest-900', 'border-forest-500', 'text-forest-700', 'dark:text-forest-300');
      } else {
        selectedMinutes = minutes;
        timeChips.forEach((other) => {
          other.classList.remove('bg-forest-100', 'dark:bg-forest-900', 'border-forest-500', 'text-forest-700', 'dark:text-forest-300');
        });
        chip.classList.add('bg-forest-100', 'dark:bg-forest-900', 'border-forest-500', 'text-forest-700', 'dark:text-forest-300');
      }
      runSuggest();
      writeToUrl(selectedStationCode, selectedMinutes);
    });
  });

  // ── Apply / clear suggestions ─────────────────────────────────────────────
  function formatSuggestionCount(count: number): string {
    if (count === 1) return translations['suggest.resultsCount.one'] || '1 suggestion';
    return (translations['suggest.resultsCount.many'] || '{count} suggestions').replace(
      '{count}',
      String(count)
    );
  }

  function applySuggestions(suggestions: Suggestion[]) {
    const matchedIds = new Set(suggestions.map((suggestion) => suggestion.hikeId));

    // Mark non-matching cards as suggest-hidden
    const cards = document.querySelectorAll<HTMLElement>('.hike-card');
    cards.forEach((card) => {
      const hikeId = card.dataset.hikeId || '';
      if (matchedIds.has(hikeId)) {
        delete card.dataset.suggestHidden;
      } else {
        card.dataset.suggestHidden = '1';
      }

      // Populate section annotation
      const annotation = card.querySelector<HTMLElement>('.suggest-annotation');
      if (annotation) {
        const suggestion = suggestions.find((s) => s.hikeId === hikeId);
        if (suggestion) {
          const directionLabel = suggestion.startsHere
            ? translations['suggest.departs'] || 'Départ'
            : translations['suggest.arrives'] || 'Arrivée';
          const sectionLabel =
            suggestion.toStep - suggestion.fromStep < (hikeIndex.find((h) => h.hikeId === hikeId)?.stepCount ?? 1)
              ? (translations['suggest.section'] || 'Étapes {from}–{to}')
                  .replace('{from}', String(suggestion.fromStep + 1))
                  .replace('{to}', String(suggestion.toStep))
              : '';
          const parts = [directionLabel];
          if (sectionLabel) parts.push(sectionLabel);
          parts.push(`${Math.round(suggestion.totalDistance * 10) / 10} km`);
          parts.push(formatDuration(suggestion.totalDuration));
          annotation.textContent = parts.join(' · ');
          annotation.classList.remove('hidden');
        } else {
          annotation.textContent = '';
          annotation.classList.add('hidden');
        }
      }
    });

    // Trigger re-filter on existing filters (they respect data-suggest-hidden)
    document.dispatchEvent(new CustomEvent('suggest-changed'));

    // Show status row
    statusRow.classList.remove('hidden');
    resultCount.textContent =
      suggestions.length > 0
        ? formatSuggestionCount(suggestions.length)
        : translations['suggest.noResults'] || 'Aucune randonnée';
  }

  function clearSuggestions() {
    const cards = document.querySelectorAll<HTMLElement>('.hike-card');
    cards.forEach((card) => {
      delete card.dataset.suggestHidden;
      const annotation = card.querySelector<HTMLElement>('.suggest-annotation');
      if (annotation) {
        annotation.textContent = '';
        annotation.classList.add('hidden');
      }
    });

    statusRow.classList.add('hidden');
    document.dispatchEvent(new CustomEvent('suggest-changed'));
  }

  function runSuggest() {
    if (!selectedStationCode || !selectedMinutes) {
      if (!selectedStationCode && !selectedMinutes) {
        clearSuggestions();
      }
      return;
    }
    const suggestions = findSuggestions(hikeIndex, selectedStationCode, selectedMinutes);
    applySuggestions(suggestions);
  }

  // ── Clear button ──────────────────────────────────────────────────────────
  clearButton.addEventListener('click', () => {
    stationInput.value = '';
    selectedStationCode = null;
    selectedMinutes = null;
    timeChips.forEach((chip) => {
      chip.classList.remove('bg-forest-100', 'dark:bg-forest-900', 'border-forest-500', 'text-forest-700', 'dark:text-forest-300');
    });
    clearSuggestions();
    writeToUrl(null, null);
  });

  // Also clear when the reset-filters event fires
  document.addEventListener('reset-filters', () => {
    stationInput.value = '';
    selectedStationCode = null;
    selectedMinutes = null;
    timeChips.forEach((chip) => {
      chip.classList.remove('bg-forest-100', 'dark:bg-forest-900', 'border-forest-500', 'text-forest-700', 'dark:text-forest-300');
    });
    statusRow.classList.add('hidden');
    // Don't call clearSuggestions here — reset-filters will re-run all filters
  });

  // ── URL state ─────────────────────────────────────────────────────────────
  function writeToUrl(stationCode: string | null, minutes: number | null) {
    const params = new URLSearchParams(window.location.search);
    if (stationCode) {
      params.set('station', stationCode);
    } else {
      params.delete('station');
    }
    if (minutes) {
      params.set('time', String(minutes));
    } else {
      params.delete('time');
    }
    const queryString = params.toString();
    const newUrl = queryString
      ? `${window.location.pathname}?${queryString}`
      : window.location.pathname;
    history.replaceState(null, '', newUrl);
  }

  function readFromUrl() {
    const params = new URLSearchParams(window.location.search);
    const stationCode = params.get('station');
    const minutes = params.get('time') ? parseInt(params.get('time')!) : null;

    if (stationCode) {
      const station = stations.find((station) => station.code === stationCode);
      if (station) {
        stationInput.value = station.name;
        selectedStationCode = station.code;
      }
    }

    if (minutes) {
      selectedMinutes = minutes;
      timeChips.forEach((chip) => {
        if (parseInt(chip.dataset.minutes || '0') === minutes) {
          chip.classList.add('bg-forest-100', 'dark:bg-forest-900', 'border-forest-500', 'text-forest-700', 'dark:text-forest-300');
        }
      });
    }
  }

  // Initialize from URL
  readFromUrl();
  if (selectedStationCode && selectedMinutes) {
    runSuggest();
  }
</script>
