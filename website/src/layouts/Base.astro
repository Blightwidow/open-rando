---
interface Props {
  title?: string;
}

const { title = 'open-rando' } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Randonnees entre gares sur les sentiers GR" />
    <link rel="icon" type="image/jpeg" href="/logo.jpg" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-stone-50 text-stone-900 dark:bg-neutral-900 dark:text-stone-100 min-h-screen transition-colors">
    <button
      id="theme-toggle"
      aria-label="Basculer theme sombre"
      class="fixed top-4 right-4 z-50 p-2 rounded-full bg-stone-200 dark:bg-neutral-700 text-stone-700 dark:text-stone-200 hover:bg-stone-300 dark:hover:bg-neutral-600 transition-colors shadow-md"
    >
      <svg id="theme-icon-sun" class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="5" />
        <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
      </svg>
      <svg id="theme-icon-moon" class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
      </svg>
    </button>
    <slot />
  </body>
</html>

<script is:inline>
  document.getElementById('theme-toggle').addEventListener('click', function () {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    document.dispatchEvent(new CustomEvent('theme-change', { detail: { dark: isDark } }));
  });
</script>

<style is:global>
  :root {
    --color-trail: #2d6a4f;
    --color-station-start: #16a34a;
    --color-station-intermediate: #d97706;
    --color-station-end: #dc2626;
  }
  .dark {
    --color-trail: #52b788;
    --color-station-start: #4ade80;
    --color-station-intermediate: #fbbf24;
    --color-station-end: #f87171;
  }

  /* Leaflet dark mode overrides */
  .dark .leaflet-popup-content-wrapper,
  .dark .leaflet-popup-tip {
    background-color: #262626;
    color: #f5f5f4;
  }
  .dark .leaflet-popup-content a {
    color: #52b788;
  }
  .dark .leaflet-control-zoom a {
    background-color: #262626;
    color: #f5f5f4;
    border-color: #3a3a3a;
  }
  .dark .leaflet-control-zoom a:hover {
    background-color: #333;
  }
  .dark .leaflet-control-attribution {
    background-color: rgba(26, 26, 26, 0.8);
    color: #a8a29e;
  }
  .dark .leaflet-control-attribution a {
    color: #78716c;
  }
  .dark .leaflet-tooltip {
    background-color: #262626;
    color: #f5f5f4;
    border-color: #3a3a3a;
  }
  .dark .leaflet-tooltip::before {
    border-top-color: #262626;
  }
</style>
