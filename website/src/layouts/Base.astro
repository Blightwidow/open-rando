---
import type { Locale } from '../lib/i18n';
import { t, getAlternateUrl } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  locale?: Locale;
}

const {
  title = 'TrainRando',
  description,
  canonicalUrl,
  ogType = 'website',
  locale = 'fr',
} = Astro.props;

const siteUrl = 'https://rando.dammaretz.fr';
const resolvedDescription = description || t(locale, 'site.description');
const resolvedCanonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const alternateLocale = locale === 'fr' ? 'en' : 'fr';
const alternateUrl = new URL(getAlternateUrl(Astro.url, alternateLocale), siteUrl).href;
const languageSwitchPath = getAlternateUrl(Astro.url, alternateLocale);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={resolvedDescription} />
    <meta name="theme-color" content="#2d6a4f" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="canonical" href={resolvedCanonical} />
    <link rel="alternate" hreflang={locale} href={resolvedCanonical} />
    <link rel="alternate" hreflang={alternateLocale} href={alternateUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={`${siteUrl}/logo.png`} />
    <meta property="og:site_name" content="TrainRando" />
    <meta property="og:locale" content={locale === 'fr' ? 'fr_FR' : 'en_GB'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={resolvedDescription} />

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-stone-50 text-stone-900 dark:bg-neutral-900 dark:text-stone-100 min-h-screen transition-colors">
    <nav class="sticky top-0 z-50 bg-stone-50/95 dark:bg-neutral-900/95 backdrop-blur border-b border-stone-200 dark:border-neutral-700">
      <div class="max-w-6xl mx-auto px-4 h-12 flex items-center justify-between">
        <a href={locale === 'en' ? '/en/' : '/'} class="flex items-center gap-2">
          <img src="/logo.png" alt="TrainRando" class="w-7 h-7 rounded" />
          <span class="font-bold text-sm">TrainRando</span>
        </a>
        <div class="flex items-center gap-3">
          <a
            href={locale === 'en' ? '/en/app' : '/app'}
            class="text-sm font-medium text-stone-600 dark:text-stone-300 hover:text-forest-700 dark:hover:text-forest-400 transition-colors"
          >
            {t(locale, 'nav.explore')}
          </a>
          <a
            href={locale === 'en' ? '/en/about' : '/about'}
            class="text-sm font-medium text-stone-600 dark:text-stone-300 hover:text-forest-700 dark:hover:text-forest-400 transition-colors hidden sm:inline"
          >
            {t(locale, 'nav.about')}
          </a>
          <a
            href={languageSwitchPath}
            class="text-xs font-medium px-2 py-1 rounded bg-stone-200 dark:bg-neutral-700 text-stone-700 dark:text-stone-200 hover:bg-stone-300 dark:hover:bg-neutral-600 transition-colors"
          >
            {t(locale, 'nav.language')}
          </a>
          <button
            id="theme-toggle"
            aria-label={t(locale, 'theme.toggle')}
            class="p-2 rounded-full bg-stone-200 dark:bg-neutral-700 text-stone-700 dark:text-stone-200 hover:bg-stone-300 dark:hover:bg-neutral-600 transition-colors"
          >
            <svg id="theme-icon-sun" class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="5" />
              <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
            </svg>
            <svg id="theme-icon-moon" class="w-4 h-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
            </svg>
          </button>
        </div>
      </div>
    </nav>
    <slot />
  </body>
</html>

<script is:inline>
  document.getElementById('theme-toggle').addEventListener('click', function () {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    document.dispatchEvent(new CustomEvent('theme-change', { detail: { dark: isDark } }));
  });
</script>

<style is:global>
  :root {
    --color-trail: #E72323;
    --color-station-start: #16a34a;
    --color-station-intermediate: #d97706;
    --color-station-end: #dc2626;
  }
  .dark {
    --color-trail: #E72323;
    --color-station-start: #4ade80;
    --color-station-intermediate: #fbbf24;
    --color-station-end: #f87171;
  }

  /* Leaflet dark mode overrides */
  .dark .leaflet-popup-content-wrapper,
  .dark .leaflet-popup-tip {
    background-color: #262626;
    color: #f5f5f4;
  }
  .dark .leaflet-popup-content a {
    color: #52b788;
  }
  .dark .leaflet-control-zoom a {
    background-color: #262626;
    color: #f5f5f4;
    border-color: #3a3a3a;
  }
  .dark .leaflet-control-zoom a:hover {
    background-color: #333;
  }
  .dark .leaflet-control-attribution {
    background-color: rgba(26, 26, 26, 0.8);
    color: #a8a29e;
  }
  .dark .leaflet-control-attribution a {
    color: #78716c;
  }
  .dark .leaflet-tooltip {
    background-color: #262626;
    color: #f5f5f4;
    border-color: #3a3a3a;
  }
  .dark .leaflet-tooltip::before {
    border-top-color: #262626;
  }

  /* Focus visible for keyboard navigation */
  *:focus-visible {
    outline: 2px solid #2d6a4f;
    outline-offset: 2px;
  }
  .dark *:focus-visible {
    outline-color: #52b788;
  }
</style>
