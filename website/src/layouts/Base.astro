---
interface Props {
  title?: string;
}

const { title = 'open-rando' } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Randonnees entre gares sur les sentiers GR" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <slot />
  </body>
</html>
