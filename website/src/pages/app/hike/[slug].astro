---
import Base from '../../../layouts/Base.astro';
import ElevationChart from '../../../components/ElevationChart.astro';
import AccommodationIcons from '../../../components/AccommodationIcons.astro';
import { getAllHikes, getHikeBySlug, formatDuration, getStationTimetableUrl } from '../../../lib/catalog';
import type { Hike } from '../../../lib/catalog';
import { t } from '../../../lib/i18n';

const locale = 'fr';

const difficultyLabels: Record<string, string> = {
  easy: t(locale, 'difficulty.easy'),
  moderate: t(locale, 'difficulty.moderate'),
  difficult: t(locale, 'difficulty.difficult'),
  very_difficult: t(locale, 'difficulty.very_difficult'),
};

const difficultyTooltips: Record<string, string> = {
  easy: t(locale, 'difficulty.tooltip.easy'),
  moderate: t(locale, 'difficulty.tooltip.moderate'),
  difficult: t(locale, 'difficulty.tooltip.difficult'),
  very_difficult: t(locale, 'difficulty.tooltip.very_difficult'),
};

export function getStaticPaths() {
  const hikes = getAllHikes();
  return hikes.map((hike) => ({
    params: { slug: hike.slug },
  }));
}

const { slug } = Astro.params;
const hike = getHikeBySlug(slug!) as Hike;

const stations = [
  ...hike.steps.map((step) => step.start_station),
  hike.steps[hike.steps.length - 1].end_station,
];

const hikeTitle = hike.is_round_trip
  ? t(locale, 'hike.loopFrom', { station: hike.start_station.name })
  : `${hike.start_station.name} → ${hike.end_station.name}`;
const hikeDescription = `${hike.path_ref}: ${hikeTitle} — ${hike.distance_km} km, ${hike.step_count} ${hike.step_count > 1 ? 'étapes' : 'étape'}, ${difficultyLabels[hike.difficulty] || hike.difficulty}`;
---

<Base
  title={`${hikeTitle} – TrainRando`}
  description={hikeDescription}
  ogType="article"
  locale={locale}
>
  <header class="max-w-4xl mx-auto px-4 py-6">
    <a href="/app" class="text-sm text-forest-700 hover:text-forest-900 dark:text-forest-400 dark:hover:text-forest-300">&larr; {t(locale, 'nav.back')}</a>
    <div class="mt-4">
      <span class="text-xs font-semibold text-forest-700 dark:text-forest-400 uppercase tracking-wide">{hike.path_ref}</span>
      <h1 class="text-2xl font-bold mt-1">
        {hikeTitle}
      </h1>
      <p class="text-stone-500 dark:text-stone-400 mt-1">{hike.path_name}</p>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 pb-12 space-y-6 sm:space-y-8">
    <div class="grid gap-6 sm:grid-cols-2">
      <div class="bg-white dark:bg-neutral-800 rounded-lg border border-stone-200 dark:border-neutral-700 p-5 space-y-3">
        <h2 class="text-lg font-semibold">{t(locale, 'detail.summary')}</h2>
        <dl class="grid grid-cols-2 gap-y-2 text-sm">
          <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.distance')}</dt>
          <dd class="font-medium">{hike.distance_km} km</dd>
          <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.estimatedDuration')}</dt>
          <dd class="font-medium">{formatDuration(hike.estimated_duration_min)}</dd>
          <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.stepCount')}</dt>
          <dd class="font-medium">{hike.step_count}</dd>
          <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.trail')}</dt>
          <dd class="font-medium">{hike.path_ref}</dd>
          {hike.elevation_gain_m > 0 && (
            <>
              <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.elevationGain')}</dt>
              <dd class="font-medium">+{hike.elevation_gain_m}m</dd>
              <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.elevationLoss')}</dt>
              <dd class="font-medium">-{hike.elevation_loss_m}m</dd>
              <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.maxAltitude')}</dt>
              <dd class="font-medium">{hike.max_elevation_m}m</dd>
            </>
          )}
          {hike.difficulty !== 'unknown' && (
            <>
              <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.difficulty')}</dt>
              <dd>
                <span
                  title={difficultyTooltips[hike.difficulty]}
                  class:list={[
                  "text-xs px-2 py-0.5 rounded-full cursor-help",
                  hike.difficulty === 'easy' ? "bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300" :
                  hike.difficulty === 'moderate' ? "bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300" :
                  hike.difficulty === 'difficult' ? "bg-orange-100 text-orange-700 dark:bg-orange-900 dark:text-orange-300" :
                  "bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300"
                ]}>
                  {difficultyLabels[hike.difficulty] || hike.difficulty}
                </span>
              </dd>
            </>
          )}
        </dl>
        <a
          href={`/data/${hike.gpx_path}`}
          download
          class="inline-flex items-center gap-1 text-sm text-forest-700 hover:text-forest-900 dark:text-forest-400 dark:hover:text-forest-300 font-medium mt-2"
        >
          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          {t(locale, 'detail.downloadGpx')}
        </a>
      </div>

      <div class="bg-white dark:bg-neutral-800 rounded-lg border border-stone-200 dark:border-neutral-700 p-5 space-y-3">
        <h2 class="text-lg font-semibold">{t(locale, 'detail.steps')}</h2>
        <ol class="space-y-2" id="step-list">
          {hike.steps.map((step, index) => (
            <li class="flex items-start gap-3 text-sm transition-opacity" data-step-index={index}>
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-forest-100 text-forest-800 dark:bg-forest-800 dark:text-forest-200 text-xs font-semibold flex items-center justify-center">
                {index + 1}
              </span>
              <div>
                <p class="font-medium flex flex-wrap items-center gap-1.5">
                  <a href={getStationTimetableUrl(step.start_station)} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-stone-100 dark:bg-neutral-700 text-stone-700 dark:text-stone-300 hover:bg-stone-200 dark:hover:bg-neutral-600 transition-colors text-xs font-semibold">
                    <svg class="w-3 h-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 17v1a2 2 0 002 2h12a2 2 0 002-2v-1M8 17l-1-5h10l-1 5M6 8h12a2 2 0 012 2v2H4v-2a2 2 0 012-2zM10 3h4v5h-4z"/></svg>
                    {step.start_station.name}
                  </a>
                  <span class="text-stone-400">&rarr;</span>
                  <a href={getStationTimetableUrl(step.end_station)} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-stone-100 dark:bg-neutral-700 text-stone-700 dark:text-stone-300 hover:bg-stone-200 dark:hover:bg-neutral-600 transition-colors text-xs font-semibold">
                    <svg class="w-3 h-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 17v1a2 2 0 002 2h12a2 2 0 002-2v-1M8 17l-1-5h10l-1 5M6 8h12a2 2 0 012 2v2H4v-2a2 2 0 012-2zM10 3h4v5h-4z"/></svg>
                    {step.end_station.name}
                  </a>
                </p>
                <p class="text-stone-500 dark:text-stone-400">
                  {step.distance_km} km &middot; {formatDuration(step.estimated_duration_min)}
                  {(step.elevation_gain_m > 0 || step.elevation_loss_m > 0) && (
                    <span> &middot; +{step.elevation_gain_m}m / -{step.elevation_loss_m}m</span>
                  )}
                </p>
                {(step.end_station.accommodation.has_hotel || step.end_station.accommodation.has_camping) && (
                  <div class="flex items-center gap-1.5 mt-0.5">
                    <AccommodationIcons
                      hasHotel={step.end_station.accommodation.has_hotel}
                      hasCamping={step.end_station.accommodation.has_camping}
                      size="sm"
                      locale={locale}
                    />
                  </div>
                )}
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>

    {hike.step_count > 1 && (
      <div id="section-selector" class="bg-white dark:bg-neutral-800 rounded-lg border border-stone-200 dark:border-neutral-700 p-5 space-y-4">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold">{t(locale, 'detail.sectionTitle')}</h2>
          <button id="section-reset" class="text-sm text-forest-700 hover:text-forest-900 dark:text-forest-400 dark:hover:text-forest-300 font-medium hidden">
            {t(locale, 'detail.sectionReset')}
          </button>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          <label class="text-sm text-stone-500 dark:text-stone-400">{t(locale, 'detail.sectionFrom')}</label>
          <select id="section-from" class="text-sm rounded-md border border-stone-300 dark:border-neutral-600 bg-white dark:bg-neutral-700 px-2 py-1">
            {stations.slice(0, -1).map((station, index) => (
              <option value={index}>{station.name}</option>
            ))}
          </select>
          <label class="text-sm text-stone-500 dark:text-stone-400">{t(locale, 'detail.sectionTo')}</label>
          <select id="section-to" class="text-sm rounded-md border border-stone-300 dark:border-neutral-600 bg-white dark:bg-neutral-700 px-2 py-1">
            {stations.slice(1).map((station, index) => (
              <option value={index + 1} selected={index === stations.length - 2}>{station.name}</option>
            ))}
          </select>
        </div>
        <div id="section-summary" class="hidden">
          <dl class="flex flex-wrap gap-x-6 gap-y-1 text-sm">
            <div><dt class="inline text-stone-500 dark:text-stone-400">{t(locale, 'detail.distance')}: </dt><dd class="inline font-medium" id="section-distance"></dd></div>
            <div><dt class="inline text-stone-500 dark:text-stone-400">{t(locale, 'detail.estimatedDuration')}: </dt><dd class="inline font-medium" id="section-duration"></dd></div>
            <div><dt class="inline text-stone-500 dark:text-stone-400">{t(locale, 'detail.elevationGain')}: </dt><dd class="inline font-medium" id="section-elevation"></dd></div>
          </dl>
          <a id="section-gpx-download" download class="inline-flex items-center gap-1 text-sm text-forest-700 hover:text-forest-900 dark:text-forest-400 dark:hover:text-forest-300 font-medium mt-2">
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            {t(locale, 'detail.sectionDownloadGpx')}
          </a>
        </div>
      </div>
    )}

    <ElevationChart hikeId={hike.id} locale={locale} />

    <div class="rounded-lg border border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-950 p-4 text-sm text-amber-800 dark:text-amber-300">
      {t(locale, 'detail.disclaimer')}
    </div>

    <div
      id="detail-map"
      class="w-full rounded-lg border border-stone-200 dark:border-neutral-700 h-[35vh] sm:h-[50vh]"
      data-hike={JSON.stringify(hike)}
    ></div>
  </main>

  <footer class="max-w-4xl mx-auto px-4 py-6 text-sm text-stone-500 dark:text-stone-400 border-t border-stone-200 dark:border-neutral-700">
    {t(locale, 'footer.data')} &copy; <a href="https://www.ign.fr/" class="underline">IGN</a> &middot; <a href="https://www.openstreetmap.org/copyright" class="underline">OpenStreetMap</a> (ODbL)
  </footer>
</Base>

<script>
  import L from 'leaflet';

  const mapElement = document.getElementById('detail-map')!;
  const hike = JSON.parse(mapElement.dataset.hike!);

  const bbox = hike.bbox;
  const map = L.map('detail-map').fitBounds([
    [bbox[1], bbox[0]],
    [bbox[3], bbox[2]],
  ], { padding: [40, 40] });

  const ignAttribution = '&copy; <a href="https://www.ign.fr/">IGN</a>';

  const openTopoLayer = L.tileLayer(
    'https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png',
    { attribution: '&copy; <a href="https://opentopomap.org">OpenTopoMap</a> &middot; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>', maxZoom: 17 },
  ).addTo(map);

  const planIgnLayer = L.tileLayer(
    'https://data.geopf.fr/wmts?SERVICE=WMTS&REQUEST=GetTile&VERSION=1.0.0&LAYER=GEOGRAPHICALGRIDSYSTEMS.PLANIGNV2&STYLE=normal&FORMAT=image/png&TILEMATRIXSET=PM&TILEMATRIX={z}&TILEROW={y}&TILECOL={x}',
    { attribution: ignAttribution, maxZoom: 18 },
  );

  L.control.layers({ 'OpenTopoMap': openTopoLayer, 'Plan IGN': planIgnLayer }).addTo(map);

  const lightStepColors = ['#E72323', '#931010'];
  const darkStepColors = ['#E72323', '#931010'];

  let trailLayers: L.Layer[] = [];

  function getThemeColors() {
    const style = getComputedStyle(document.documentElement);
    return {
      trail: style.getPropertyValue('--color-trail').trim(),
      stationStart: style.getPropertyValue('--color-station-start').trim(),
      stationIntermediate: style.getPropertyValue('--color-station-intermediate').trim(),
      stationEnd: style.getPropertyValue('--color-station-end').trim(),
      stepColors: document.documentElement.classList.contains('dark') ? darkStepColors : lightStepColors,
    };
  }

  let cachedGeojson: any = null;

  function buildLayers() {
    trailLayers.forEach((layer) => map.removeLayer(layer));
    trailLayers = [];

    if (!cachedGeojson) return;

    const colors = getThemeColors();

    cachedGeojson.features.forEach((feature: any, index: number) => {
      const color = colors.stepColors[index % colors.stepColors.length];
      const layer = L.geoJSON(feature, {
        style: { color, weight: 4, opacity: 0.85 },
      }).addTo(map);
      trailLayers.push(layer);
    });

    const startColor = hike.is_round_trip ? colors.stationIntermediate : colors.stationStart;
    const startMarker = L.circleMarker([hike.start_station.lat, hike.start_station.lon], {
      radius: 7, color: startColor, fillColor: startColor, fillOpacity: 0.9, weight: 2,
    }).bindTooltip(hike.start_station.name, { permanent: true, direction: 'top', offset: [0, -8] }).addTo(map);
    trailLayers.push(startMarker);

    if (hike.steps.length > 1) {
      for (let stepIndex = 1; stepIndex < hike.steps.length; stepIndex++) {
        const station = hike.steps[stepIndex].start_station;
        const marker = L.circleMarker([station.lat, station.lon], {
          radius: 5, color: colors.stationIntermediate, fillColor: colors.stationIntermediate, fillOpacity: 0.9, weight: 2,
        }).bindTooltip(station.name, { permanent: true, direction: 'top', offset: [0, -8] }).addTo(map);
        trailLayers.push(marker);
      }
    }

    if (!hike.is_round_trip) {
      const endMarker = L.circleMarker([hike.end_station.lat, hike.end_station.lon], {
        radius: 7, color: colors.stationEnd, fillColor: colors.stationEnd, fillOpacity: 0.9, weight: 2,
      }).bindTooltip(hike.end_station.name, { permanent: true, direction: 'top', offset: [0, -8] }).addTo(map);
      trailLayers.push(endMarker);
    }

    if (trailLayers.length > 0) {
      map.fitBounds(L.featureGroup(trailLayers).getBounds(), { padding: [40, 40] });
    }
  }

  async function loadHike() {
    const response = await fetch(`/data/${hike.geojson_path}`);
    cachedGeojson = await response.json();
    buildLayers();
  }

  let sectionFrom = 0;
  let sectionTo = hike.steps.length;

  function buildLayers_withSection() {
    buildLayers();
    if (sectionFrom !== 0 || sectionTo !== hike.steps.length) {
      applySectionToMap(sectionFrom, sectionTo);
    }
  }

  function applySectionToMap(from: number, to: number) {
    if (!cachedGeojson) return;
    const featureCount = cachedGeojson.features.length;

    for (let index = 0; index < featureCount; index++) {
      const layer = trailLayers[index] as L.GeoJSON;
      if (!layer || !('setStyle' in layer)) continue;
      const isSelected = index >= from && index < to;
      layer.setStyle({
        opacity: isSelected ? 0.85 : 0.15,
        weight: isSelected ? 4 : 2,
      });
    }

    const markerOffset = featureCount;
    const allMarkerLayers = trailLayers.slice(markerOffset);
    allMarkerLayers.forEach((marker, markerIndex) => {
      if ('setStyle' in marker) {
        const stationIndex = markerIndex === 0 ? 0 : markerIndex;
        const isInRange = stationIndex >= from && stationIndex <= to;
        (marker as L.CircleMarker).setStyle({ opacity: isInRange ? 1 : 0.2, fillOpacity: isInRange ? 0.9 : 0.2 });
        const tooltip = (marker as any).getTooltip();
        if (tooltip) {
          (marker as any).closeTooltip();
          if (isInRange) (marker as any).openTooltip();
        }
      }
    });

    const selectedLayers: L.Layer[] = [];
    for (let index = from; index < to; index++) {
      if (trailLayers[index]) selectedLayers.push(trailLayers[index]);
    }
    if (selectedLayers.length > 0) {
      map.fitBounds(L.featureGroup(selectedLayers).getBounds(), { padding: [40, 40] });
    }
  }

  document.addEventListener('section-change', ((event: CustomEvent) => {
    sectionFrom = event.detail.from;
    sectionTo = event.detail.to;
    applySectionToMap(sectionFrom, sectionTo);
  }) as EventListener);

  document.addEventListener('theme-change', (() => {
    buildLayers_withSection();
  }) as EventListener);

  loadHike();
</script>

<script>
  const sectionSelector = document.getElementById('section-selector');
  if (sectionSelector) {
    const mapElement = document.getElementById('detail-map')!;
    const hike = JSON.parse(mapElement.dataset.hike!);
    const fromSelect = document.getElementById('section-from') as HTMLSelectElement;
    const toSelect = document.getElementById('section-to') as HTMLSelectElement;
    const resetButton = document.getElementById('section-reset')!;
    const summaryDiv = document.getElementById('section-summary')!;
    const distanceDisplay = document.getElementById('section-distance')!;
    const durationDisplay = document.getElementById('section-duration')!;
    const elevationDisplay = document.getElementById('section-elevation')!;
    const gpxDownloadLink = document.getElementById('section-gpx-download') as HTMLAnchorElement;
    const stepItems = document.querySelectorAll('#step-list li[data-step-index]');
    const totalSteps = hike.steps.length;

    function formatDuration(minutes: number): string {
      const hours = Math.floor(minutes / 60);
      const mins = Math.round(minutes % 60);
      if (hours > 0 && mins > 0) return `${hours}h${String(mins).padStart(2, '0')}`;
      if (hours > 0) return `${hours}h`;
      return `${mins}min`;
    }

    function getFromValue(): number {
      return parseInt(fromSelect.value, 10);
    }

    function getToValue(): number {
      return parseInt(toSelect.value, 10);
    }

    function isFullRange(): boolean {
      return getFromValue() === 0 && getToValue() === totalSteps;
    }

    function constrainSelects() {
      const from = getFromValue();
      for (const option of Array.from(toSelect.options)) {
        const value = parseInt(option.value, 10);
        option.disabled = value <= from;
      }
      if (getToValue() <= from) {
        toSelect.value = String(from + 1);
      }
    }

    function updateSection() {
      constrainSelects();
      const from = getFromValue();
      const to = getToValue();
      const full = isFullRange();

      resetButton.classList.toggle('hidden', full);
      summaryDiv.classList.toggle('hidden', full);

      if (!full) {
        const selectedSteps = hike.steps.slice(from, to);
        const distance = selectedSteps.reduce((sum: number, step: any) => sum + step.distance_km, 0);
        const duration = selectedSteps.reduce((sum: number, step: any) => sum + step.estimated_duration_min, 0);
        const elevationGain = selectedSteps.reduce((sum: number, step: any) => sum + step.elevation_gain_m, 0);
        const elevationLoss = selectedSteps.reduce((sum: number, step: any) => sum + step.elevation_loss_m, 0);

        distanceDisplay.textContent = `${distance.toFixed(1)} km`;
        durationDisplay.textContent = formatDuration(duration);
        elevationDisplay.textContent = `+${elevationGain}m / -${elevationLoss}m`;
      }

      stepItems.forEach((item) => {
        const index = parseInt((item as HTMLElement).dataset.stepIndex!, 10);
        const isSelected = index >= from && index < to;
        (item as HTMLElement).style.opacity = full || isSelected ? '1' : '0.3';
      });

      const url = new URL(window.location.href);
      if (full) {
        url.searchParams.delete('from');
        url.searchParams.delete('to');
      } else {
        url.searchParams.set('from', String(from));
        url.searchParams.set('to', String(to));
      }
      history.replaceState(null, '', url.toString());

      document.dispatchEvent(new CustomEvent('section-change', { detail: { from, to, full } }));
    }

    async function buildSectionGpx(from: number, to: number) {
      try {
        const response = await fetch(`/data/${hike.gpx_path}`);
        const gpxText = await response.text();
        const parser = new DOMParser();
        const newGpx = parser.parseFromString(gpxText, 'text/xml');
        const newTrack = newGpx.querySelector('trk')!;
        const newSegments = newTrack.querySelectorAll('trkseg');
        newSegments.forEach((segment, index) => {
          if (index < from || index >= to) {
            segment.remove();
          }
        });

        const serializer = new XMLSerializer();
        const gpxString = serializer.serializeToString(newGpx);
        const blob = new Blob([gpxString], { type: 'application/gpx+xml' });

        if (gpxDownloadLink.href.startsWith('blob:')) {
          URL.revokeObjectURL(gpxDownloadLink.href);
        }
        gpxDownloadLink.href = URL.createObjectURL(blob);
        gpxDownloadLink.download = `${hike.slug}-section-${from + 1}-${to}.gpx`;
      } catch {
        gpxDownloadLink.style.display = 'none';
      }
    }

    fromSelect.addEventListener('change', () => {
      updateSection();
      if (!isFullRange()) buildSectionGpx(getFromValue(), getToValue());
    });

    toSelect.addEventListener('change', () => {
      updateSection();
      if (!isFullRange()) buildSectionGpx(getFromValue(), getToValue());
    });

    resetButton.addEventListener('click', () => {
      fromSelect.value = '0';
      toSelect.value = String(totalSteps);
      updateSection();
    });

    const urlParams = new URLSearchParams(window.location.search);
    const urlFrom = urlParams.get('from');
    const urlTo = urlParams.get('to');
    if (urlFrom !== null && urlTo !== null) {
      fromSelect.value = urlFrom;
      toSelect.value = urlTo;
      updateSection();
      buildSectionGpx(getFromValue(), getToValue());
    }
  }
</script>
