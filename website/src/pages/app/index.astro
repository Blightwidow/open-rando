---
import Base from '../../layouts/Base.astro';
import RouteList from '../../components/RouteList.astro';
import RouteFilters from '../../components/RouteFilters.astro';
import { getAllRoutes } from '../../lib/catalog';
import { t } from '../../lib/i18n';

const locale = 'fr';
const routes = getAllRoutes();
const routesMeta = routes.map((route) => ({
  id: route.id,
  slug: route.slug,
  geojson_path: route.geojson_path,
  bbox: route.bbox,
  path_name: route.path_name,
  path_ref: route.path_ref,
}));
---

<Base
  title={`TrainRando — ${t(locale, 'site.subtitle')}`}
  description={t(locale, 'site.description')}
  locale={locale}
>
  <!-- Mobile: stacked layout / Desktop: fixed sidebar + scrollable main -->
  <div class="lg:flex lg:h-[calc(100vh-3rem)]">
    <!-- Sidebar -->
    <aside class="px-4 py-5 border-b border-stone-200 dark:border-neutral-700 lg:border-b-0 lg:border-r lg:w-72 lg:shrink-0 lg:overflow-y-auto lg:py-6 lg:px-5">
      <RouteFilters routes={routes} locale={locale} />
    </aside>

    <!-- Main content -->
    <div class="flex-1 lg:overflow-y-auto">
      <div class="px-4 sm:px-6 py-6 pb-12 space-y-4">
        <!-- Header with count + tab switcher -->
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold">
            <span id="route-count">{routes.length}</span> {locale === 'fr' ? 'sentiers' : 'trails'}
          </h2>
          <div class="flex border border-stone-300 dark:border-neutral-600 rounded-md overflow-hidden text-sm">
            <button id="tab-list" class="px-3 py-1.5 bg-forest-700 text-white font-medium" data-view="list">
              {t(locale, 'tabs.list')}
            </button>
            <button id="tab-map" class="px-3 py-1.5 text-stone-600 dark:text-stone-300 hover:bg-stone-100 dark:hover:bg-neutral-700" data-view="map">
              {t(locale, 'tabs.map')}
            </button>
          </div>
        </div>

        <!-- List view (default) -->
        <div id="view-list">
          <RouteList routes={routes} locale={locale} />
        </div>

        <!-- Map view (hidden, lazy-loaded) -->
        <div id="view-map" class="hidden">
          <div
            id="app-map"
            class="relative rounded-lg border border-stone-200 dark:border-neutral-700 overflow-hidden"
            style="height: calc(100vh - 12rem);"
            data-routes-meta={JSON.stringify(routesMeta)}
            data-locale={locale}
          ></div>
        </div>
      </div>
      <footer class="px-4 sm:px-6 py-6 text-sm text-stone-500 dark:text-stone-400 border-t border-stone-200 dark:border-neutral-700">
        {t(locale, 'footer.data')} &copy; <a href="https://www.openstreetmap.org/copyright" class="underline">OpenStreetMap</a> (ODbL)
        &middot; <a href="https://github.com/Blightwidow/open-rando" class="underline">GitHub</a>
      </footer>
    </div>
  </div>
</Base>

<script>
  const tabList = document.getElementById('tab-list')!;
  const tabMap = document.getElementById('tab-map')!;
  const viewList = document.getElementById('view-list')!;
  const viewMap = document.getElementById('view-map')!;

  function switchTab(view: 'list' | 'map') {
    const isList = view === 'list';

    viewList.classList.toggle('hidden', !isList);
    viewMap.classList.toggle('hidden', isList);

    for (const button of [tabList, tabMap]) {
      const isActive = button.dataset.view === view;
      button.className = isActive
        ? 'px-3 py-1.5 bg-forest-700 text-white font-medium'
        : 'px-3 py-1.5 text-stone-600 dark:text-stone-300 hover:bg-stone-100 dark:hover:bg-neutral-700';
    }

    const params = new URLSearchParams(window.location.search);
    if (view === 'map') params.set('view', 'map');
    else params.delete('view');
    const queryString = params.toString();
    history.replaceState(null, '', queryString ? `${window.location.pathname}?${queryString}` : window.location.pathname);

    if (view === 'map') {
      document.dispatchEvent(new CustomEvent('map-tab-activated'));
    }
  }

  tabList.addEventListener('click', () => switchTab('list'));
  tabMap.addEventListener('click', () => switchTab('map'));

  if (new URLSearchParams(window.location.search).get('view') === 'map') {
    switchTab('map');
  }
</script>

<script>
  import 'maplibre-gl/dist/maplibre-gl.css';
  import maplibregl from 'maplibre-gl';
  import { createMap, switchTheme, TRAIL_COLOR } from '../../lib/map';

  interface RouteMeta {
    id: string;
    slug: string;
    geojson_path: string;
    bbox: [number, number, number, number];
    path_name: string;
    path_ref: string;
  }

  let mapInstance: maplibregl.Map | null = null;
  const routeSourceIds: string[] = [];
  let allRoutesLoaded = false;

  async function initMap() {
    if (mapInstance) {
      mapInstance.resize();
      return;
    }

    const container = document.getElementById('app-map')!;
    const routesMeta: RouteMeta[] = JSON.parse(container.dataset.routesMeta!);
    const locale = container.dataset.locale || 'fr';
    const prefix = locale === 'en' ? '/en' : '';

    const map = createMap(container);
    mapInstance = map;

    // Loading overlay
    const loadingOverlay = document.createElement('div');
    loadingOverlay.className = 'absolute inset-0 z-[1000] flex items-center justify-center bg-white/70 dark:bg-neutral-900/70';
    loadingOverlay.innerHTML = '<span class="text-sm text-stone-500 dark:text-stone-400">Chargement des sentiers…</span>';
    container.appendChild(loadingOverlay);

    await new Promise<void>((resolve) => {
      if (map.isStyleLoaded()) resolve();
      else map.on('load', () => resolve());
    });

    // Fetch all GeoJSON traces in parallel
    await Promise.allSettled(
      routesMeta.map(async (meta) => {
        const response = await fetch(`/data/${meta.geojson_path}`);
        const geojson = await response.json();
        const trailFeatures = geojson.features.filter(
          (feature: any) => feature.properties.feature_type === 'trail'
        );

        const sourceId = `route-${meta.id}`;
        const layerId = `route-line-${meta.id}`;
        routeSourceIds.push(sourceId);

        map.addSource(sourceId, {
          type: 'geojson',
          data: { type: 'FeatureCollection', features: trailFeatures },
        });

        map.addLayer({
          id: layerId,
          type: 'line',
          source: sourceId,
          paint: {
            'line-color': TRAIL_COLOR,
            'line-width': 3,
            'line-opacity': 0.8,
          },
        });

        // Hover: thicken line
        map.on('mouseenter', layerId, () => {
          map.getCanvas().style.cursor = 'pointer';
          map.setPaintProperty(layerId, 'line-width', 5);
          map.setPaintProperty(layerId, 'line-opacity', 1);
        });
        map.on('mouseleave', layerId, () => {
          map.getCanvas().style.cursor = '';
          map.setPaintProperty(layerId, 'line-width', 3);
          map.setPaintProperty(layerId, 'line-opacity', 0.8);
        });

        // Tooltip on hover
        const tooltip = new maplibregl.Popup({
          closeButton: false,
          closeOnClick: false,
        });
        map.on('mousemove', layerId, (event) => {
          tooltip
            .setLngLat(event.lngLat)
            .setHTML(`${meta.path_ref} — ${meta.path_name}`)
            .addTo(map);
        });
        map.on('mouseleave', layerId, () => {
          tooltip.remove();
        });

        // Click: navigate to route detail
        map.on('click', layerId, () => {
          window.location.href = `${prefix}/app/route/${meta.slug}`;
        });
      })
    );

    allRoutesLoaded = true;
    loadingOverlay.remove();

    applyMapFilters();
    fitMapToVisible(routesMeta);

    // Theme switching: re-apply style and re-add route layers
    document.addEventListener('theme-change', () => {
      if (!mapInstance) return;
      switchTheme(mapInstance);
      // After style reload, sources/layers are gone — need to re-init
      mapInstance.once('style.load', () => {
        reloadRouteLayers(routesMeta, prefix);
      });
    });
  }

  async function reloadRouteLayers(routesMeta: RouteMeta[], prefix: string) {
    if (!mapInstance) return;
    const map = mapInstance;
    routeSourceIds.length = 0;

    await Promise.allSettled(
      routesMeta.map(async (meta) => {
        const response = await fetch(`/data/${meta.geojson_path}`);
        const geojson = await response.json();
        const trailFeatures = geojson.features.filter(
          (feature: any) => feature.properties.feature_type === 'trail'
        );

        const sourceId = `route-${meta.id}`;
        const layerId = `route-line-${meta.id}`;
        routeSourceIds.push(sourceId);

        map.addSource(sourceId, {
          type: 'geojson',
          data: { type: 'FeatureCollection', features: trailFeatures },
        });

        map.addLayer({
          id: layerId,
          type: 'line',
          source: sourceId,
          paint: {
            'line-color': TRAIL_COLOR,
            'line-width': 3,
            'line-opacity': 0.8,
          },
        });

        map.on('mouseenter', layerId, () => {
          map.getCanvas().style.cursor = 'pointer';
          map.setPaintProperty(layerId, 'line-width', 5);
          map.setPaintProperty(layerId, 'line-opacity', 1);
        });
        map.on('mouseleave', layerId, () => {
          map.getCanvas().style.cursor = '';
          map.setPaintProperty(layerId, 'line-width', 3);
          map.setPaintProperty(layerId, 'line-opacity', 0.8);
        });

        const tooltip = new maplibregl.Popup({ closeButton: false, closeOnClick: false });
        map.on('mousemove', layerId, (event) => {
          tooltip.setLngLat(event.lngLat).setHTML(`${meta.path_ref} — ${meta.path_name}`).addTo(map);
        });
        map.on('mouseleave', layerId, () => { tooltip.remove(); });
        map.on('click', layerId, () => {
          window.location.href = `${prefix}/app/route/${meta.slug}`;
        });
      })
    );

    allRoutesLoaded = true;
    applyMapFilters();
  }

  function getVisibleRouteIds(): Set<string> {
    const visibleIds = new Set<string>();
    document.querySelectorAll<HTMLElement>('.route-card').forEach((card) => {
      if (card.style.display !== 'none') visibleIds.add(card.dataset.routeId!);
    });
    return visibleIds;
  }

  function applyMapFilters() {
    if (!mapInstance || !allRoutesLoaded) return;
    const visible = getVisibleRouteIds();
    for (const sourceId of routeSourceIds) {
      const routeId = sourceId.replace('route-', '');
      const layerId = `route-line-${routeId}`;
      if (mapInstance.getLayer(layerId)) {
        mapInstance.setLayoutProperty(layerId, 'visibility', visible.has(routeId) ? 'visible' : 'none');
      }
    }
  }

  function fitMapToVisible(routesMeta?: RouteMeta[]) {
    if (!mapInstance) return;
    const visible = getVisibleRouteIds();
    const container = document.getElementById('app-map')!;
    const metas: RouteMeta[] = routesMeta ?? JSON.parse(container.dataset.routesMeta!);
    const bounds = new maplibregl.LngLatBounds();
    let hasBounds = false;
    for (const meta of metas) {
      if (visible.has(meta.id)) {
        // bbox is [minLon, minLat, maxLon, maxLat]
        bounds.extend([meta.bbox[0], meta.bbox[1]]);
        bounds.extend([meta.bbox[2], meta.bbox[3]]);
        hasBounds = true;
      }
    }
    if (hasBounds) mapInstance.fitBounds(bounds, { padding: 30 });
  }

  document.addEventListener('map-tab-activated', () => {
    initMap().then(() => {
      setTimeout(() => mapInstance?.resize(), 50);
    });
  });

  document.addEventListener('filters-applied', () => {
    applyMapFilters();
    fitMapToVisible();
  });
</script>
