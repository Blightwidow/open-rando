---
import Base from '../../layouts/Base.astro';
import ElevationChart from '../../components/ElevationChart.astro';
import { getAllHikes, getHikeBySlug, formatDuration } from '../../lib/catalog';
import type { Hike } from '../../lib/catalog';

const difficultyLabels: Record<string, string> = {
  easy: 'Facile',
  moderate: 'Modere',
  difficult: 'Difficile',
  very_difficult: 'Tres difficile',
};

export function getStaticPaths() {
  const hikes = getAllHikes();
  return hikes.map((hike) => ({
    params: { slug: hike.slug },
  }));
}

const { slug } = Astro.params;
const hike = getHikeBySlug(slug!) as Hike;

const stations = [
  ...hike.steps.map((step) => step.start_station),
  hike.steps[hike.steps.length - 1].end_station,
];
---

<Base title={`${hike.start_station.name} → ${hike.end_station.name} – open-rando`}>
  <header class="max-w-4xl mx-auto px-4 py-6">
    <a href="/" class="text-sm text-forest-700 hover:text-forest-900 dark:text-forest-400 dark:hover:text-forest-300">&larr; Toutes les randonnees</a>
    <div class="mt-4">
      <span class="text-xs font-semibold text-forest-700 dark:text-forest-400 uppercase tracking-wide">{hike.path_ref}</span>
      <h1 class="text-2xl font-bold mt-1">
        {hike.start_station.name} &rarr; {hike.end_station.name}
      </h1>
      <p class="text-stone-500 dark:text-stone-400 mt-1">{hike.path_name}</p>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 pb-12 space-y-8">
    <div class="grid gap-6 sm:grid-cols-2">
      <div class="bg-white dark:bg-neutral-800 rounded-lg border border-stone-200 dark:border-neutral-700 p-5 space-y-3">
        <h2 class="text-lg font-semibold">Resume</h2>
        <dl class="grid grid-cols-2 gap-y-2 text-sm">
          <dt class="text-stone-500 dark:text-stone-400">Distance</dt>
          <dd class="font-medium">{hike.distance_km} km</dd>
          <dt class="text-stone-500 dark:text-stone-400">Duree estimee</dt>
          <dd class="font-medium">{formatDuration(hike.estimated_duration_min)}</dd>
          <dt class="text-stone-500 dark:text-stone-400">Nombre d'etapes</dt>
          <dd class="font-medium">{hike.step_count}</dd>
          <dt class="text-stone-500 dark:text-stone-400">Sentier</dt>
          <dd class="font-medium">{hike.path_ref}</dd>
          {hike.elevation_gain_m > 0 && (
            <>
              <dt class="text-stone-500 dark:text-stone-400">Denivele positif</dt>
              <dd class="font-medium">+{hike.elevation_gain_m}m</dd>
              <dt class="text-stone-500 dark:text-stone-400">Denivele negatif</dt>
              <dd class="font-medium">-{hike.elevation_loss_m}m</dd>
              <dt class="text-stone-500 dark:text-stone-400">Altitude max</dt>
              <dd class="font-medium">{hike.max_elevation_m}m</dd>
            </>
          )}
          {hike.difficulty !== 'unknown' && (
            <>
              <dt class="text-stone-500 dark:text-stone-400">Difficulte</dt>
              <dd class="font-medium">{difficultyLabels[hike.difficulty] || hike.difficulty}</dd>
            </>
          )}
        </dl>
        <a
          href={`/data/${hike.gpx_path}`}
          download
          class="inline-flex items-center gap-1 text-sm text-forest-700 hover:text-forest-900 dark:text-forest-400 dark:hover:text-forest-300 font-medium mt-2"
        >
          Telecharger GPX
        </a>
      </div>

      <div class="bg-white dark:bg-neutral-800 rounded-lg border border-stone-200 dark:border-neutral-700 p-5 space-y-3">
        <h2 class="text-lg font-semibold">Etapes</h2>
        <ol class="space-y-2">
          {hike.steps.map((step, index) => (
            <li class="flex items-start gap-3 text-sm">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-forest-100 text-forest-800 dark:bg-forest-800 dark:text-forest-200 text-xs font-semibold flex items-center justify-center">
                {index + 1}
              </span>
              <div>
                <p class="font-medium">
                  {step.start_station.name} &rarr; {step.end_station.name}
                </p>
                <p class="text-stone-500 dark:text-stone-400">
                  {step.distance_km} km &middot; {formatDuration(step.estimated_duration_min)}
                  {(step.elevation_gain_m > 0 || step.elevation_loss_m > 0) && (
                    <span> &middot; +{step.elevation_gain_m}m / -{step.elevation_loss_m}m</span>
                  )}
                </p>
                <p class="text-xs text-gray-400 mt-0.5">
                  {step.end_station.accommodation.has_hotel && step.end_station.accommodation.has_camping
                    ? "Hotel & Camping"
                    : step.end_station.accommodation.has_hotel
                      ? "Hotel"
                      : step.end_station.accommodation.has_camping
                        ? "Camping"
                        : "Pas d'hebergement repertorie"}
                </p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <ElevationChart hikeId={hike.id} />

    <div class="bg-white dark:bg-neutral-800 rounded-lg border border-stone-200 dark:border-neutral-700 p-5">
      <h2 class="text-lg font-semibold mb-3">Gares</h2>
      <div class="flex flex-wrap gap-2">
        {stations.map((station, index) => (
          <div class="flex items-center gap-1">
            <span class:list={[
              "text-sm px-3 py-1 rounded-full",
              index === 0
                ? "bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300"
                : index === stations.length - 1
                  ? "bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300"
                  : "bg-amber-100 text-amber-700 dark:bg-amber-900 dark:text-amber-300",
            ]}>
              {station.name}
            </span>
            {station.accommodation.has_hotel && <span class="text-xs bg-purple-100 text-purple-700 dark:bg-purple-900 dark:text-purple-300 px-1.5 py-0.5 rounded-full">Hotel</span>}
            {station.accommodation.has_camping && <span class="text-xs bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300 px-1.5 py-0.5 rounded-full">Camping</span>}
          </div>
        ))}
      </div>
    </div>

    <div
      id="detail-map"
      class="w-full rounded-lg border border-stone-200 dark:border-neutral-700"
      style="height: 50vh;"
      data-hike={JSON.stringify(hike)}
    ></div>
  </main>

  <footer class="max-w-4xl mx-auto px-4 py-6 text-sm text-stone-500 dark:text-stone-400 border-t border-stone-200 dark:border-neutral-700">
    Donnees &copy; <a href="https://www.ign.fr/" class="underline">IGN</a> &middot; <a href="https://www.openstreetmap.org/copyright" class="underline">OpenStreetMap</a> (ODbL)
  </footer>
</Base>

<script>
  import L from 'leaflet';

  const mapElement = document.getElementById('detail-map')!;
  const hike = JSON.parse(mapElement.dataset.hike!);

  const bbox = hike.bbox;
  const map = L.map('detail-map').fitBounds([
    [bbox[1], bbox[0]],
    [bbox[3], bbox[2]],
  ], { padding: [40, 40] });

  const ignAttribution = '&copy; <a href="https://www.ign.fr/">IGN</a>';

  const planIgnLayer = L.tileLayer(
    'https://data.geopf.fr/wmts?SERVICE=WMTS&REQUEST=GetTile&VERSION=1.0.0&LAYER=GEOGRAPHICALGRIDSYSTEMS.PLANIGNV2&STYLE=normal&FORMAT=image/png&TILEMATRIXSET=PM&TILEMATRIX={z}&TILEROW={y}&TILECOL={x}',
    { attribution: ignAttribution, maxZoom: 18 },
  ).addTo(map);

  const openTopoLayer = L.tileLayer(
    'https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png',
    { attribution: '&copy; <a href="https://opentopomap.org">OpenTopoMap</a> &middot; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>', maxZoom: 17 },
  );

  L.control.layers({ 'Plan IGN': planIgnLayer, 'OpenTopoMap': openTopoLayer }).addTo(map);

  const lightStepColors = ['#2d6a4f', '#7c3aed', '#db2777', '#ea580c', '#16a34a', '#0891b2'];
  const darkStepColors = ['#52b788', '#a78bfa', '#f472b6', '#fb923c', '#4ade80', '#22d3ee'];

  let trailLayers: L.Layer[] = [];

  function getThemeColors() {
    const style = getComputedStyle(document.documentElement);
    return {
      trail: style.getPropertyValue('--color-trail').trim(),
      stationStart: style.getPropertyValue('--color-station-start').trim(),
      stationIntermediate: style.getPropertyValue('--color-station-intermediate').trim(),
      stationEnd: style.getPropertyValue('--color-station-end').trim(),
      stepColors: document.documentElement.classList.contains('dark') ? darkStepColors : lightStepColors,
    };
  }

  let cachedGeojson: any = null;

  function buildLayers() {
    trailLayers.forEach((layer) => map.removeLayer(layer));
    trailLayers = [];

    if (!cachedGeojson) return;

    const colors = getThemeColors();

    cachedGeojson.features.forEach((feature: any, index: number) => {
      const color = colors.stepColors[index % colors.stepColors.length];
      const layer = L.geoJSON(feature, {
        style: { color, weight: 4, opacity: 0.85 },
      }).addTo(map);
      trailLayers.push(layer);
    });

    const startMarker = L.circleMarker([hike.start_station.lat, hike.start_station.lon], {
      radius: 7, color: colors.stationStart, fillColor: colors.stationStart, fillOpacity: 0.9, weight: 2,
    }).bindTooltip(hike.start_station.name, { permanent: true, direction: 'top', offset: [0, -8] }).addTo(map);
    trailLayers.push(startMarker);

    if (hike.steps.length > 1) {
      for (let stepIndex = 1; stepIndex < hike.steps.length; stepIndex++) {
        const station = hike.steps[stepIndex].start_station;
        const marker = L.circleMarker([station.lat, station.lon], {
          radius: 5, color: colors.stationIntermediate, fillColor: colors.stationIntermediate, fillOpacity: 0.9, weight: 2,
        }).bindTooltip(station.name, { permanent: true, direction: 'top', offset: [0, -8] }).addTo(map);
        trailLayers.push(marker);
      }
    }

    const endMarker = L.circleMarker([hike.end_station.lat, hike.end_station.lon], {
      radius: 7, color: colors.stationEnd, fillColor: colors.stationEnd, fillOpacity: 0.9, weight: 2,
    }).bindTooltip(hike.end_station.name, { permanent: true, direction: 'top', offset: [0, -8] }).addTo(map);
    trailLayers.push(endMarker);

    if (trailLayers.length > 0) {
      map.fitBounds(L.featureGroup(trailLayers).getBounds(), { padding: [40, 40] });
    }
  }

  async function loadHike() {
    const response = await fetch(`/data/${hike.geojson_path}`);
    cachedGeojson = await response.json();
    buildLayers();
  }

  document.addEventListener('theme-change', (() => {
    buildLayers();
  }) as EventListener);

  loadHike();
</script>
