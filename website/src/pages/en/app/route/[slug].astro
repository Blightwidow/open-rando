---
import Base from '../../../../layouts/Base.astro';
import ElevationChart from '../../../../components/ElevationChart.astro';
import SearchableSelect from '../../../../components/SearchableSelect.astro';
import { getAllRoutes, getRouteBySlug, getTrainStations } from '../../../../lib/catalog';
import type { Route } from '../../../../lib/catalog';
import { t } from '../../../../lib/i18n';

const locale = 'en';

export function getStaticPaths() {
  const routes = getAllRoutes();
  return routes.map((route) => ({
    params: { slug: route.slug },
  }));
}

const { slug } = Astro.params;
const route = getRouteBySlug(slug!) as Route;
const pois = route.pois ?? [];
const trainStations = getTrainStations(route);
const hotelCount = pois.filter((poi) => poi.poi_type === 'hotel').length;
const campingCount = pois.filter((poi) => poi.poi_type === 'camping').length;
const busStopCount = pois.filter((poi) => poi.poi_type === 'bus_stop').length;
---

<Base
  title={`${route.path_ref} – TrainRando`}
  description={`${route.path_name} — ${route.distance_km} km, ${trainStations.length} stations`}
  ogType="article"
  locale={locale}
>
  <header class="max-w-4xl mx-auto px-4 py-6">
    <a href="/en/app" class="text-sm text-forest-700 hover:text-forest-900 dark:text-forest-400 dark:hover:text-forest-300">&larr; {t(locale, 'nav.back')}</a>
    <div class="mt-4">
      <span class="text-xs font-semibold text-forest-700 dark:text-forest-400 uppercase tracking-wide">{route.path_ref}</span>
      <h1 class="text-2xl font-bold mt-1">{route.path_name}</h1>
      {route.description && (
        <p class="mt-2 text-sm text-stone-600 dark:text-stone-400 leading-relaxed">{route.description}</p>
      )}
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 pb-12 space-y-6 sm:space-y-8">
    <div class="bg-white dark:bg-neutral-800 rounded-lg border border-stone-200 dark:border-neutral-700 p-5 space-y-3">
      <h2 class="text-lg font-semibold">{t(locale, 'detail.summary')}</h2>
      <dl class="grid grid-cols-2 sm:grid-cols-3 gap-y-2 text-sm">
        <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.distance')}</dt>
        <dd class="font-medium">{route.distance_km} km</dd>
        <div></div>
        <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.trail')}</dt>
        <dd class="font-medium">{route.path_ref}</dd>
        <div></div>
        {route.elevation_gain_m > 0 && (
          <>
            <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.elevationGain')}</dt>
            <dd class="font-medium">+{route.elevation_gain_m}m</dd>
            <div></div>
            <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.elevationLoss')}</dt>
            <dd class="font-medium">-{route.elevation_loss_m}m</dd>
            <div></div>
            <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.maxAltitude')}</dt>
            <dd class="font-medium">{route.max_elevation_m}m</dd>
            <div></div>
          </>
        )}
      </dl>
      <div class="flex flex-wrap gap-2 mt-2">
        <span class="text-xs bg-forest-100 text-forest-800 dark:bg-forest-800 dark:text-forest-200 px-2 py-0.5 rounded-full">{trainStations.length} stations</span>
        {busStopCount > 0 && <span class="text-xs bg-blue-100 text-blue-800 dark:bg-blue-800 dark:text-blue-200 px-2 py-0.5 rounded-full">{busStopCount} bus stops</span>}
        {hotelCount > 0 && <span class="text-xs bg-purple-100 text-purple-800 dark:bg-purple-800 dark:text-purple-200 px-2 py-0.5 rounded-full">{hotelCount} hotels</span>}
        {campingCount > 0 && <span class="text-xs bg-amber-100 text-amber-800 dark:bg-amber-800 dark:text-amber-200 px-2 py-0.5 rounded-full">{campingCount} campsites</span>}
      </div>
      <a
        href={`/data/${route.gpx_path}`}
        download
        class="inline-flex items-center gap-2 mt-2 px-4 py-2 bg-forest-700 text-white rounded-md hover:bg-forest-800 transition-colors text-sm font-medium"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 10v6m0 0l-3-3m3 3l3-3M3 17v3a1 1 0 001 1h16a1 1 0 001-1v-3"/></svg>
        {t(locale, 'detail.downloadGpx')}
      </a>
    </div>

    {trainStations.filter((station) => station.distance_km != null).length >= 3 && (
      <div
        id="section-selector"
        class="bg-white dark:bg-neutral-800 rounded-lg border border-stone-200 dark:border-neutral-700 p-5 space-y-4"
        data-stations={JSON.stringify(
          trainStations
            .filter((station) => station.distance_km != null)
            .sort((stationA, stationB) => stationA.distance_km! - stationB.distance_km!)
            .map((station) => ({ name: station.name, distance_km: station.distance_km }))
        )}
        data-route-id={route.id}
        data-route-ref={route.path_ref}
      >
        <h2 class="text-lg font-semibold">{t(locale, 'detail.sectionTitle')}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label class="block text-sm text-stone-500 dark:text-stone-400 mb-1">{t(locale, 'detail.sectionFrom')}</label>
            <SearchableSelect id="section-from" placeholder="—" />
          </div>
          <div>
            <label class="block text-sm text-stone-500 dark:text-stone-400 mb-1">{t(locale, 'detail.sectionTo')}</label>
            <SearchableSelect id="section-to" placeholder="—" />
          </div>
        </div>
        <div id="section-stats" class="hidden">
          <dl class="grid grid-cols-2 sm:grid-cols-4 gap-y-2 text-sm">
            <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.distance')}</dt>
            <dd id="section-distance" class="font-medium"></dd>
            <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.elevationGain')}</dt>
            <dd id="section-gain" class="font-medium"></dd>
            <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.estimatedDuration')}</dt>
            <dd id="section-duration" class="font-medium"></dd>
            <dt class="text-stone-500 dark:text-stone-400">{t(locale, 'detail.elevationLoss')}</dt>
            <dd id="section-loss" class="font-medium"></dd>
          </dl>
          <div class="flex flex-wrap gap-3 mt-3">
            <button id="section-download-gpx" class="inline-flex items-center gap-2 px-4 py-2 bg-forest-700 text-white rounded-md hover:bg-forest-800 transition-colors text-sm font-medium">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 10v6m0 0l-3-3m3 3l3-3M3 17v3a1 1 0 001 1h16a1 1 0 001-1v-3"/></svg>
              {t(locale, 'detail.sectionDownloadGpx')}
            </button>
            <button id="section-reset" class="text-sm text-forest-700 dark:text-forest-400 hover:underline">
              {t(locale, 'detail.sectionReset')}
            </button>
          </div>
        </div>
      </div>
    )}

    <ElevationChart routeId={route.id} locale={locale} />

    <div
      id="detail-map"
      class="bg-white dark:bg-neutral-800 rounded-lg border border-stone-200 dark:border-neutral-700 overflow-hidden"
      style="height: 450px;"
      data-route={JSON.stringify(route)}
    >
    </div>

    <p class="text-xs text-stone-400 dark:text-stone-500 leading-relaxed">
      {t(locale, 'detail.disclaimer')}
    </p>
  </main>
</Base>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<script>
  import L from 'leaflet';

  const mapElement = document.getElementById('detail-map')!;
  const routeData = JSON.parse(mapElement.dataset.route!);

  const map = L.map(mapElement, { zoomControl: true, scrollWheelZoom: true });

  const isDark = document.documentElement.classList.contains('dark');
  L.tileLayer(
    isDark
      ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png'
      : 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
    { attribution: '&copy; OpenStreetMap contributors', maxZoom: 18 }
  ).addTo(map);

  const trailLayer = L.layerGroup().addTo(map);
  const trainLayer = L.layerGroup().addTo(map);
  const busLayer = L.layerGroup().addTo(map);
  const hotelLayer = L.layerGroup().addTo(map);
  const campingLayer = L.layerGroup().addTo(map);

  const poiStyles: Record<string, { radius: number; fillColor: string; layer: L.LayerGroup }> = {
    train_station: { radius: 7, fillColor: '#22c55e', layer: trainLayer },
    bus_stop:      { radius: 5, fillColor: '#3b82f6', layer: busLayer },
    hotel:         { radius: 5, fillColor: '#a855f7', layer: hotelLayer },
    camping:       { radius: 5, fillColor: '#f59e0b', layer: campingLayer },
  };

  async function loadRoute() {
    try {
      const response = await fetch(`/data/${routeData.geojson_path}`);
      const geojson = await response.json();

      const trailFeatures = geojson.features.filter((feature: any) => feature.properties.feature_type === 'trail');
      for (const feature of trailFeatures) {
        L.geoJSON(feature, {
          style: { color: 'var(--color-trail, #E72323)', weight: 3, opacity: 0.8 },
        }).addTo(trailLayer);
      }

      for (const poi of routeData.pois ?? []) {
        const style = poiStyles[poi.poi_type];
        if (!style) continue;

        const marker = L.circleMarker([poi.lat, poi.lon], {
          radius: style.radius,
          fillColor: style.fillColor,
          color: '#fff',
          weight: 2,
          fillOpacity: 0.9,
        }).addTo(style.layer);

        const lines = poi.transit_lines?.length
          ? `<br><span class="text-xs text-blue-600">${poi.transit_lines.join(', ')}</span>`
          : '';
        const urlLabel = (poi.poi_type === 'hotel' || poi.poi_type === 'camping') ? 'Website' : 'Timetable';
        let popupContent = `<strong>${poi.name}</strong><br><span class="text-xs">${poi.poi_type.replace('_', ' ')}</span>${lines}`;
        if (poi.url) {
          popupContent += `<br><a href="${poi.url}" target="_blank" rel="noopener noreferrer" class="text-xs underline">${urlLabel}</a>`;
        }
        marker.bindPopup(popupContent);
      }

      const bounds = L.geoJSON(geojson).getBounds();
      map.fitBounds(bounds, { padding: [30, 30] });

      // Build distance-to-coordinate lookup for elevation chart sync
      const allCoords: [number, number][] = [];
      for (const feature of trailFeatures) {
        const geom = feature.geometry;
        const rings = geom.type === 'MultiLineString' ? geom.coordinates : [geom.coordinates];
        for (const ring of rings) {
          for (const coord of ring) {
            allCoords.push([coord[1], coord[0]]);
          }
        }
      }

      function haversine(lat1: number, lon1: number, lat2: number, lon2: number): number {
        const earthRadiusKm = 6371;
        const deltaLat = (lat2 - lat1) * Math.PI / 180;
        const deltaLon = (lon2 - lon1) * Math.PI / 180;
        const halfChordSquared = Math.sin(deltaLat / 2) ** 2
          + Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.sin(deltaLon / 2) ** 2;
        return earthRadiusKm * 2 * Math.atan2(Math.sqrt(halfChordSquared), Math.sqrt(1 - halfChordSquared));
      }

      const cumulativeDistances: number[] = [0];
      for (let index = 1; index < allCoords.length; index++) {
        const segmentDistance = haversine(allCoords[index - 1][0], allCoords[index - 1][1], allCoords[index][0], allCoords[index][1]);
        cumulativeDistances.push(cumulativeDistances[index - 1] + segmentDistance);
      }
      const totalTrailDistance = cumulativeDistances[cumulativeDistances.length - 1];

      let hoverMarker: L.CircleMarker | null = null;

      document.addEventListener('elevation-hover', ((event: CustomEvent) => {
        const distanceKm = event.detail.distanceKm;

        if (distanceKm === null || totalTrailDistance === 0) {
          if (hoverMarker) { map.removeLayer(hoverMarker); hoverMarker = null; }
          return;
        }

        const fraction = Math.min(distanceKm / totalTrailDistance, 1);
        const targetDistance = fraction * totalTrailDistance;

        let low = 0;
        let high = cumulativeDistances.length - 1;
        while (low < high - 1) {
          const mid = (low + high) >> 1;
          if (cumulativeDistances[mid] <= targetDistance) low = mid; else high = mid;
        }

        const segmentLength = cumulativeDistances[high] - cumulativeDistances[low];
        const interpolation = segmentLength > 0 ? (targetDistance - cumulativeDistances[low]) / segmentLength : 0;
        const lat = allCoords[low][0] + (allCoords[high][0] - allCoords[low][0]) * interpolation;
        const lon = allCoords[low][1] + (allCoords[high][1] - allCoords[low][1]) * interpolation;

        if (hoverMarker) {
          hoverMarker.setLatLng([lat, lon]);
        } else {
          hoverMarker = L.circleMarker([lat, lon], {
            radius: 7,
            fillColor: '#E72323',
            color: '#fff',
            weight: 2,
            fillOpacity: 1,
          }).addTo(map);
        }
      }) as EventListener);

      // Section highlighting
      let sectionHighlightLayer: L.Polyline | null = null;
      let originalTrailOpacity = 0.8;

      document.addEventListener('section-change', ((event: CustomEvent) => {
        // Remove previous highlight
        if (sectionHighlightLayer) {
          map.removeLayer(sectionHighlightLayer);
          sectionHighlightLayer = null;
        }

        // Reset trail opacity
        trailLayer.eachLayer((layer: any) => {
          if (layer.setStyle) layer.setStyle({ opacity: originalTrailOpacity });
        });

        const detail = event.detail;
        if (!detail || detail.startKm == null || detail.endKm == null) return;

        const { startKm, endKm } = detail;

        // Dim main trail
        trailLayer.eachLayer((layer: any) => {
          if (layer.setStyle) layer.setStyle({ opacity: 0.25 });
        });

        // Find coordinate indices for section
        function findCoordIndex(targetKm: number): number {
          let low = 0;
          let high = cumulativeDistances.length - 1;
          while (low < high - 1) {
            const mid = (low + high) >> 1;
            if (cumulativeDistances[mid] <= targetKm) low = mid; else high = mid;
          }
          return low;
        }

        const startIndex = findCoordIndex(startKm);
        const endIndex = Math.min(findCoordIndex(endKm) + 1, allCoords.length - 1);

        const sectionCoords = allCoords.slice(startIndex, endIndex + 1);
        if (sectionCoords.length >= 2) {
          sectionHighlightLayer = L.polyline(sectionCoords, {
            color: '#2563eb',
            weight: 5,
            opacity: 0.9,
          }).addTo(map);
          map.fitBounds(sectionHighlightLayer.getBounds(), { padding: [30, 30] });
        }
      }) as EventListener);

      // If a section was already selected (e.g. restored from URL before map loaded),
      // re-apply it now that the listener is ready.
      const fromSelect = document.getElementById('section-from') as HTMLSelectElement | null;
      const toSelect = document.getElementById('section-to') as HTMLSelectElement | null;
      if (fromSelect?.value && toSelect?.value && fromSelect.value !== toSelect.value) {
        let startKm = parseFloat(fromSelect.value);
        let endKm = parseFloat(toSelect.value);
        if (startKm > endKm) { const tmp = startKm; startKm = endKm; endKm = tmp; }
        document.dispatchEvent(new CustomEvent('section-change', {
          detail: { startKm, endKm }
        }));
      }

    } catch (error) {
      console.error('Failed to load route GeoJSON:', error);
    }
  }

  // Layer control
  function colorDot(color: string, label: string): string {
    return `<span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:${color};margin-right:6px;vertical-align:middle;"></span>${label}`;
  }
  const overlays: Record<string, L.LayerGroup> = {
    [colorDot('#22c55e', 'Stations')]: trainLayer,
    [colorDot('#3b82f6', 'Bus stops')]: busLayer,
    [colorDot('#a855f7', 'Hotels')]: hotelLayer,
    [colorDot('#f59e0b', 'Campsites')]: campingLayer,
  };
  L.control.layers(undefined, overlays, { collapsed: false, position: 'topright' }).addTo(map);
  L.control.scale({ metric: true, imperial: false }).addTo(map);

  document.addEventListener('theme-change', () => {
    const dark = document.documentElement.classList.contains('dark');
    map.eachLayer((layer) => { if ((layer as any)._url) map.removeLayer(layer); });
    L.tileLayer(
      dark
        ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png'
        : 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
      { attribution: '&copy; OpenStreetMap contributors', maxZoom: 18 }
    ).addTo(map);
  });

  loadRoute();
</script>

<script>
  import type { RouteElevationProfile } from '../../../../lib/catalog';
  import { formatTime } from '../../../../lib/elevation';

  const selectorElement = document.getElementById('section-selector');
  if (selectorElement) {
    const stations: { name: string; distance_km: number }[] = JSON.parse(selectorElement.dataset.stations!);
    const routeId = selectorElement.dataset.routeId!;
    const routeRef = selectorElement.dataset.routeRef!;

    const fromSelect = document.getElementById('section-from') as HTMLSelectElement;
    const toSelect = document.getElementById('section-to') as HTMLSelectElement;
    const statsContainer = document.getElementById('section-stats')!;
    const distanceDisplay = document.getElementById('section-distance')!;
    const gainDisplay = document.getElementById('section-gain')!;
    const lossDisplay = document.getElementById('section-loss')!;
    const durationDisplay = document.getElementById('section-duration')!;
    const downloadButton = document.getElementById('section-download-gpx')!;
    const resetButton = document.getElementById('section-reset')!;

    // Populate dropdowns
    for (const station of stations) {
      const optionFrom = document.createElement('option');
      optionFrom.value = String(station.distance_km);
      optionFrom.textContent = station.name;
      fromSelect.appendChild(optionFrom);

      const optionTo = document.createElement('option');
      optionTo.value = String(station.distance_km);
      optionTo.textContent = station.name;
      toSelect.appendChild(optionTo);
    }

    let elevationProfile: RouteElevationProfile | null = null;

    async function loadElevationProfile(): Promise<RouteElevationProfile | null> {
      if (elevationProfile) return elevationProfile;
      try {
        const response = await fetch(`/data/elevation/${routeId}.json`);
        if (!response.ok) return null;
        elevationProfile = await response.json();
        return elevationProfile;
      } catch {
        return null;
      }
    }

    function findProfileIndex(distances: number[], targetKm: number): number {
      let low = 0;
      let high = distances.length - 1;
      while (low < high - 1) {
        const mid = (low + high) >> 1;
        if (distances[mid] <= targetKm) low = mid; else high = mid;
      }
      return low;
    }

    function updateUrlParams(fromValue: string, toValue: string) {
      const url = new URL(window.location.href);
      if (fromValue && toValue) {
        url.searchParams.set('from', fromValue);
        url.searchParams.set('to', toValue);
      } else {
        url.searchParams.delete('from');
        url.searchParams.delete('to');
      }
      window.history.replaceState({}, '', url.toString());
    }

    async function updateSection() {
      const fromValue = fromSelect.value;
      const toValue = toSelect.value;

      if (!fromValue || !toValue || fromValue === toValue) {
        statsContainer.classList.add('hidden');
        updateUrlParams('', '');
        document.dispatchEvent(new CustomEvent('section-change', { detail: null }));
        return;
      }

      let startKm = parseFloat(fromValue);
      let endKm = parseFloat(toValue);
      if (startKm > endKm) {
        const temporary = startKm;
        startKm = endKm;
        endKm = temporary;
      }

      const profile = await loadElevationProfile();
      if (!profile) return;

      const startIndex = findProfileIndex(profile.distances_km, startKm);
      const endIndex = findProfileIndex(profile.distances_km, endKm);

      // Compute section stats
      const sectionDistanceKm = Math.abs(endKm - startKm);
      let gain = 0;
      let loss = 0;
      for (let index = startIndex; index < endIndex; index++) {
        const delta = profile.elevations_m[index + 1] - profile.elevations_m[index];
        if (delta > 0) gain += delta;
        else loss += Math.abs(delta);
      }

      const durationMinutes = profile.times_min[endIndex] - profile.times_min[startIndex];

      distanceDisplay.textContent = `${sectionDistanceKm.toFixed(1)} km`;
      gainDisplay.textContent = `+${Math.round(gain)}m`;
      lossDisplay.textContent = `-${Math.round(loss)}m`;
      durationDisplay.textContent = formatTime(Math.abs(durationMinutes));

      statsContainer.classList.remove('hidden');

      updateUrlParams(fromValue, toValue);

      document.dispatchEvent(new CustomEvent('section-change', {
        detail: { startKm, endKm }
      }));
    }

    fromSelect.addEventListener('change', updateSection);
    toSelect.addEventListener('change', updateSection);

    resetButton.addEventListener('click', () => {
      fromSelect.value = '';
      toSelect.value = '';
      statsContainer.classList.add('hidden');
      updateUrlParams('', '');
      document.dispatchEvent(new CustomEvent('section-change', { detail: null }));
    });

    // Restore section from URL params on page load
    const urlParams = new URLSearchParams(window.location.search);
    const urlFrom = urlParams.get('from');
    const urlTo = urlParams.get('to');
    if (urlFrom && urlTo) {
      const validValues = new Set(stations.map((station) => String(station.distance_km)));
      if (validValues.has(urlFrom) && validValues.has(urlTo)) {
        fromSelect.value = urlFrom;
        toSelect.value = urlTo;
        updateSection();
      }
    }

    downloadButton.addEventListener('click', async () => {
      const fromValue = fromSelect.value;
      const toValue = toSelect.value;
      if (!fromValue || !toValue) return;

      let startKm = parseFloat(fromValue);
      let endKm = parseFloat(toValue);
      if (startKm > endKm) {
        const temporary = startKm;
        startKm = endKm;
        endKm = temporary;
      }

      const fromName = stations.find((station) => String(station.distance_km) === fromValue)?.name ?? '';
      const toName = stations.find((station) => String(station.distance_km) === toValue)?.name ?? '';

      // Get trail coordinates from the map's GeoJSON data
      const mapElement = document.getElementById('detail-map')!;
      const routeData = JSON.parse(mapElement.dataset.route!);
      const geojsonResponse = await fetch(`/data/${routeData.geojson_path}`);
      const geojson = await geojsonResponse.json();

      const trailFeatures = geojson.features.filter((feature: any) => feature.properties.feature_type === 'trail');
      const allCoords: [number, number][] = [];
      for (const feature of trailFeatures) {
        const geometry = feature.geometry;
        const rings = geometry.type === 'MultiLineString' ? geometry.coordinates : [geometry.coordinates];
        for (const ring of rings) {
          for (const coord of ring) {
            allCoords.push([coord[1], coord[0]]); // [lat, lon]
          }
        }
      }

      // Build cumulative distances
      function haversine(lat1: number, lon1: number, lat2: number, lon2: number): number {
        const earthRadiusKm = 6371;
        const deltaLat = (lat2 - lat1) * Math.PI / 180;
        const deltaLon = (lon2 - lon1) * Math.PI / 180;
        const halfChordSquared = Math.sin(deltaLat / 2) ** 2
          + Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.sin(deltaLon / 2) ** 2;
        return earthRadiusKm * 2 * Math.atan2(Math.sqrt(halfChordSquared), Math.sqrt(1 - halfChordSquared));
      }

      const cumulativeDistances: number[] = [0];
      for (let index = 1; index < allCoords.length; index++) {
        const segmentDistance = haversine(allCoords[index - 1][0], allCoords[index - 1][1], allCoords[index][0], allCoords[index][1]);
        cumulativeDistances.push(cumulativeDistances[index - 1] + segmentDistance);
      }

      // Find coordinate range for section
      function findCoordIndex(targetKm: number): number {
        let low = 0;
        let high = cumulativeDistances.length - 1;
        while (low < high - 1) {
          const mid = (low + high) >> 1;
          if (cumulativeDistances[mid] <= targetKm) low = mid; else high = mid;
        }
        return low;
      }

      const startIndex = findCoordIndex(startKm);
      const endIndex = Math.min(findCoordIndex(endKm) + 1, allCoords.length - 1);
      const sectionCoords = allCoords.slice(startIndex, endIndex + 1);

      // Get elevation data for section coordinates
      const profile = await loadElevationProfile();

      // Build GPX — use absolute indices to look up cumulative distance per coord
      let trackPoints = '';
      for (let coordOffset = 0; coordOffset < sectionCoords.length; coordOffset++) {
        const [lat, lon] = sectionCoords[coordOffset];
        let elevation = '';
        if (profile) {
          const absoluteIndex = startIndex + coordOffset;
          const coordDistanceKm = absoluteIndex < cumulativeDistances.length
            ? cumulativeDistances[absoluteIndex]
            : endKm;
          const profileIndex = findProfileIndex(profile.distances_km, coordDistanceKm);
          if (profileIndex < profile.elevations_m.length) {
            elevation = `<ele>${profile.elevations_m[profileIndex].toFixed(1)}</ele>`;
          }
        }
        trackPoints += `      <trkpt lat="${lat.toFixed(6)}" lon="${lon.toFixed(6)}">${elevation}</trkpt>\n`;
      }

      const gpxContent = `<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="TrainRando" xmlns="http://www.topografix.com/GPX/1/1">
  <trk>
    <name>${routeRef} — ${fromName} → ${toName}</name>
    <trkseg>
${trackPoints}    </trkseg>
  </trk>
</gpx>`;

      const blob = new Blob([gpxContent], { type: 'application/gpx+xml' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      const safeFrom = fromName.replace(/\s+/g, '-');
      const safeTo = toName.replace(/\s+/g, '-');
      link.download = `${routeRef.replace(/\s+/g, '-')}_${safeFrom}_${safeTo}.gpx`;
      link.click();
      URL.revokeObjectURL(url);
    });
  }
</script>
