---
import Landing from '../../layouts/Landing.astro';
import { t } from '../../lib/i18n';

const locale = 'en';
---

<Landing
  title={`TrainRando — ${t(locale, 'landing.hero.title')}`}
  description={t(locale, 'site.description')}
  locale={locale}
>
  <!-- Hero -->
  <section class="relative text-white overflow-hidden">
    <div class="absolute inset-0">
      <div class="flex flex-col w-full h-full min-w-[1024px]" style="font-size:0;line-height:0;">
        <div class="flex flex-1">
          <img src="https://a.tile.opentopomap.org/7/63/44.png" alt="" class="flex-1 object-cover block" loading="eager" />
          <img src="https://b.tile.opentopomap.org/7/64/44.png" alt="" class="flex-1 object-cover block" loading="eager" />
          <img src="https://c.tile.opentopomap.org/7/65/44.png" alt="" class="flex-1 object-cover block" loading="eager" />
          <img src="https://a.tile.opentopomap.org/7/66/44.png" alt="" class="flex-1 object-cover block" loading="eager" />
        </div>
        <div class="flex flex-1">
          <img src="https://b.tile.opentopomap.org/7/63/45.png" alt="" class="flex-1 object-cover block" loading="eager" />
          <img src="https://c.tile.opentopomap.org/7/64/45.png" alt="" class="flex-1 object-cover block" loading="eager" />
          <img src="https://a.tile.opentopomap.org/7/65/45.png" alt="" class="flex-1 object-cover block" loading="eager" />
          <img src="https://b.tile.opentopomap.org/7/66/45.png" alt="" class="flex-1 object-cover block" loading="eager" />
        </div>
      </div>
      <div class="absolute inset-0 bg-forest-900/75"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 py-20 sm:py-28 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight">
        {t(locale, 'landing.hero.title')}
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-white/85 max-w-2xl mx-auto leading-relaxed">
        {t(locale, 'landing.hero.subtitle')}
      </p>
      <a
        href="/en/app"
        class="inline-block mt-8 px-8 py-3 bg-white text-forest-800 font-semibold rounded-lg shadow-lg hover:bg-stone-100 transition-colors"
      >
        {t(locale, 'landing.hero.cta')}
      </a>
    </div>
  </section>

  <!-- Features -->
  <section class="max-w-6xl mx-auto px-4 py-16 sm:py-20">
    <h2 class="text-2xl sm:text-3xl font-bold text-center mb-12">{t(locale, 'landing.features.title')}</h2>
    <div class="grid sm:grid-cols-2 gap-6 sm:gap-8">
      <div class="bg-white dark:bg-neutral-800 rounded-xl border border-stone-200 dark:border-neutral-700 p-6 space-y-3">
        <div class="w-10 h-10 rounded-lg bg-forest-100 dark:bg-forest-900 flex items-center justify-center">
          <svg class="w-5 h-5 text-forest-700 dark:text-forest-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M8 18l-2 2M16 18l2 2M12 2v4M7 8h10M9 22h6M6 6h12a2 2 0 012 2v8a2 2 0 01-2 2H6a2 2 0 01-2-2V8a2 2 0 012-2z" />
          </svg>
        </div>
        <h3 class="font-semibold text-lg">{t(locale, 'landing.feature.train.title')}</h3>
        <p class="text-stone-600 dark:text-stone-400">{t(locale, 'landing.feature.train.description')}</p>
      </div>

      <div class="bg-white dark:bg-neutral-800 rounded-xl border border-stone-200 dark:border-neutral-700 p-6 space-y-3">
        <div class="w-10 h-10 rounded-lg bg-forest-100 dark:bg-forest-900 flex items-center justify-center">
          <svg class="w-5 h-5 text-forest-700 dark:text-forest-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M13 7l-3 5h4l-3 5M3 17l4-8 4 8M17 17l2-4 2 4" />
          </svg>
        </div>
        <h3 class="font-semibold text-lg">{t(locale, 'landing.feature.gr.title')}</h3>
        <p class="text-stone-600 dark:text-stone-400">{t(locale, 'landing.feature.gr.description')}</p>
      </div>

      <div class="bg-white dark:bg-neutral-800 rounded-xl border border-stone-200 dark:border-neutral-700 p-6 space-y-3">
        <div class="w-10 h-10 rounded-lg bg-forest-100 dark:bg-forest-900 flex items-center justify-center">
          <svg class="w-5 h-5 text-forest-700 dark:text-forest-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 21h18M3 10l9-7 9 7M5 10v11M19 10v11M9 21v-6h6v6" />
          </svg>
        </div>
        <h3 class="font-semibold text-lg">{t(locale, 'landing.feature.accommodation.title')}</h3>
        <p class="text-stone-600 dark:text-stone-400">{t(locale, 'landing.feature.accommodation.description')}</p>
      </div>

      <div class="bg-white dark:bg-neutral-800 rounded-xl border border-stone-200 dark:border-neutral-700 p-6 space-y-3">
        <div class="w-10 h-10 rounded-lg bg-forest-100 dark:bg-forest-900 flex items-center justify-center">
          <svg class="w-5 h-5 text-forest-700 dark:text-forest-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M12 10v6M12 16l-3-3M12 16l3-3M20 4H4a1 1 0 00-1 1v14a1 1 0 001 1h16a1 1 0 001-1V5a1 1 0 00-1-1z" />
          </svg>
        </div>
        <h3 class="font-semibold text-lg">{t(locale, 'landing.feature.gpx.title')}</h3>
        <p class="text-stone-600 dark:text-stone-400">{t(locale, 'landing.feature.gpx.description')}</p>
      </div>
    </div>
  </section>

  <!-- Privacy callout -->
  <section class="bg-stone-100 dark:bg-neutral-800/50">
    <div class="max-w-4xl mx-auto px-4 py-14 sm:py-16 text-center">
      <div class="w-14 h-14 rounded-full bg-forest-100 dark:bg-forest-900 flex items-center justify-center mx-auto mb-6">
        <svg class="w-7 h-7 text-forest-700 dark:text-forest-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
        </svg>
      </div>
      <h2 class="text-2xl font-bold mb-4">{t(locale, 'landing.privacy.title')}</h2>
      <p class="text-stone-600 dark:text-stone-400 max-w-xl mx-auto leading-relaxed">
        {t(locale, 'landing.privacy.description')}
      </p>
    </div>
  </section>

  <!-- Mobile app teaser -->
  <section class="max-w-4xl mx-auto px-4 py-14 sm:py-16">
    <div class="border-2 border-dashed border-stone-300 dark:border-neutral-600 rounded-xl p-8 sm:p-10 text-center">
      <div class="w-14 h-14 rounded-full bg-stone-100 dark:bg-neutral-800 flex items-center justify-center mx-auto mb-6">
        <svg class="w-7 h-7 text-stone-500 dark:text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <rect x="7" y="2" width="10" height="20" rx="2" />
          <path d="M12 18h.01" />
        </svg>
      </div>
      <h2 class="text-2xl font-bold mb-4">{t(locale, 'landing.mobile.title')}</h2>
      <p class="text-stone-600 dark:text-stone-400 max-w-lg mx-auto leading-relaxed">
        {t(locale, 'landing.mobile.description')}
      </p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="max-w-4xl mx-auto px-4 pb-16 text-center">
    <a
      href="/en/app"
      class="inline-block px-8 py-3 bg-forest-700 hover:bg-forest-800 text-white font-semibold rounded-lg shadow-lg transition-colors"
    >
      {t(locale, 'landing.hero.cta')}
    </a>
  </section>
</Landing>
